// ═════════════════════════════════════════════════════════════════════════════
// TENANT — Multi-tenancy SaaS
// ═════════════════════════════════════════════════════════════════════════════

/// Tenant = Loja/Revendedora cadastrada na plataforma AutoDrive
model Tenant {
  id                      String       @id @default(cuid())
  publicId                String       @unique // ex: AD-7K92P00LJ01
  slug                    String       @unique // ex: easycar-sp
  name                    String // nome comercial da loja (= nomeFantasia ou razaoSocial)
  razaoSocial             String?
  nomeFantasia            String?
  cnpj                    String?      @unique
  cpf                     String?
  inscricaoEstadual       String?
  isentoInscricaoEstadual Boolean      @default(false)
  situacaoCadastral       String? // ATIVA, INAPTA, BAIXADA, SUSPENSA
  dataAbertura            DateTime?
  cnaeCode                String? // CNAE principal ex: "4511-1/01"
  // Endereço estruturado (adicional ao address legado)
  address                 String? // campo legado — string única
  logradouro              String?
  numero                  String?
  complemento             String?
  bairro                  String?
  city                    String?
  state                   String?
  zipCode                 String? // CEP normalizado (sem hífen)
  phone                   String?
  email                   String?
  logoUrl                 String?
  faviconUrl              String?
  slogan                  String?
  primaryColor            String?      @default("#166534")
  secondaryColor          String?
  plan                    TenantPlan   @default(BASICO)
  status                  TenantStatus @default(TESTE)
  statusReason            String? // motivo de suspensão/banimento
  responsavel             String? // nome do responsável
  responsavelEmail        String?
  responsavelPhone        String?
  trialEndsAt             DateTime?
  // Limites do plano
  maxUsers                Int          @default(10)
  maxVehicles             Int          @default(100)
  maxUnits                Int          @default(1)
  notes                   String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  // Relations
  units         Unit[]
  users         User[]
  modules       TenantModule[]
  deals         Deal[]
  partners      TenantPartner[]
  featureFlags  TenantFeatureFlag[]
  goals         Goal[]
  rankingRules  RankingRule[]
  rankingScores RankingScore[]

  @@index([status])
  @@index([publicId])
  @@index([cnpj])
  @@map("tenants")
}

/// Controle de módulos ativados por tenant (substituição do plano fixo)
model TenantModule {
  id         String    @id @default(cuid())
  tenantId   String
  module     String // ex: 'commissions', 'crm', 'marketing'
  active     Boolean   @default(true)
  limit      Int? // limite de uso (0 = ilimitado)
  enabledAt  DateTime?
  disabledAt DateTime?
  enabledBy  String? // userId de quem ativou (MASTER)
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, module])
  @@index([tenantId])
  @@map("tenant_modules")
}

/// Sócios/responsáveis vinculados ao tenant (contrato social)
model TenantPartner {
  id             String      @id @default(cuid())
  tenantId       String
  cpf            String // CPF normalizado (somente dígitos)
  nomeCompleto   String
  rg             String?
  celular        String? // normalizado (somente dígitos)
  email          String?
  dataNascimento DateTime?
  role           PartnerRole @default(SOCIO)
  participacao   Decimal?    @db.Decimal(5, 2) // % de participação/cota
  principal      Boolean     @default(false) // sócio majoritário / responsável principal
  // Endereço do sócio
  cep            String?
  logradouro     String?
  numero         String?
  complemento    String?
  bairro         String?
  cidade         String?
  estado         String?
  // Usuário criado automaticamente para este sócio
  userId         String?     @unique
  active         Boolean     @default(true)
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([cpf])
  @@map("tenant_partners")
}

// ═════════════════════════════════════════════════════════════════════════════
// USUÁRIOS & ACESSO
// ═════════════════════════════════════════════════════════════════════════════

model User {
  id                 String     @id @default(cuid())
  tenantId           String? // null = usuário de plataforma (MASTER)
  name               String
  email              String     @unique
  cpf                String?    @unique
  phone              String?
  passwordHash       String
  role               UserRole   @default(USUARIO)
  status             UserStatus @default(PENDENTE)
  unitId             String?
  image              String?
  mustChangePassword Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  lastLoginAt        DateTime?

  // Relations
  tenant                  Tenant?                   @relation(fields: [tenantId], references: [id])
  unit                    Unit?                     @relation(fields: [unitId], references: [id])
  seller                  Seller?
  manager                 Manager?
  notifications           Notification[]
  commissionExtracts      CommissionExtract[]
  commissionAdjustments   CommissionAdjustment[]
  systemSettings          SystemSetting[]           @relation("SettingUpdatedBy")
  auditLogs               AuditLog[]
  passwordResets          PasswordReset[]
  apiTokens               ApiToken[]
  pendenciesResolved      Pendency[]                @relation("ResolvedByUser")
  pendenciesAssigned      Pendency[]                @relation("AssignedPendencies")
  pendenciesValidated     Pendency[]                @relation("ValidatedPendencies")
  pendenciesEscalated     Pendency[]                @relation("EscalatedByUser")
  pendencyStatusHistory   PendencyStatusHistory[]   @relation("ChangedByUser")
  pendencyComments        PendencyComment[]
  importJobs              ImportJob[]
  notificationDeliveries  NotificationDelivery[]
  notificationPreference  NotificationPreference?
  contractParseResults    ContractParseResult[]
  dealReleaseRequests     DealReleaseRequest[]      @relation("ReleasedByUser")
  managedDeals            Deal[]                    @relation("DealManager")
  vehicleEvaluations      VehicleEvaluation[]       @relation("EvaluatedByUser")
  resolvedStockPendencies VehicleStockPendency[]    @relation("ResolvedStockPendencies")
  tenantPartner           TenantPartner?
  notificationRules       NotificationRule[]        @relation("NotificationRuleCreator")
  mobileDevices           MobileDevice[]
  communicationTestLogs   CommunicationTestLog[]    @relation("CommunicationTestLogs")
  autoSyncJobs            GoogleSheetsAutoSyncJob[] @relation("AutoSyncJobCreator")

  positionId String?
  position   Position? @relation("UserPosition", fields: [positionId], references: [id])

  goals         Goal[]         @relation("UserGoals")
  rankingScores RankingScore[] @relation("UserRankingScores")
  userModules   UserModule[]

  @@index([tenantId])
  @@index([email])
  @@index([cpf])
  @@index([positionId])
  @@map("users")
}

// Liberação/remoção de módulos POR COLABORADOR (override do padrão do cargo).
// Sem registro = usa o padrão do papel (canAccessModule). allowed=false REMOVE
// o módulo para este usuário (esconde do menu e barra na API).
model UserModule {
  id        String   @id @default(cuid())
  userId    String
  moduleKey String
  allowed   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleKey])
  @@index([userId])
  @@map("user_modules")
}

model Unit {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  razaoSocial String?
  cnpj        String   @unique
  address     String?
  city        String?
  state       String?
  zipCode     String?
  phone       String?
  email       String?
  responsavel String?
  active      Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant             Tenant?             @relation(fields: [tenantId], references: [id])
  users              User[]
  sellers            Seller[]
  managers           Manager[]
  pendencies         Pendency[]
  commissionRules    CommissionRule[]
  commissionExtracts CommissionExtract[]
  stockVehicles      Vehicle[]           @relation("UnitStockVehicles")
  evaluations        VehicleEvaluation[] @relation("UnitEvaluations")
  goals              Goal[]              @relation("UnitGoals")
  rankingScores      RankingScore[]      @relation("UnitRankingScores")

  @@index([tenantId])
  @@map("units")
}

model Seller {
  id             String    @id @default(cuid())
  userId         String    @unique
  fullName       String
  shortName      String?
  cpf            String?   @unique
  rg             String?
  birthDate      DateTime?
  whatsapp       String?
  email          String?
  unitId         String
  managerId      String?
  cargo          String?
  active         Boolean   @default(true)
  receivesCharge Boolean   @default(true)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  user            User                @relation(fields: [userId], references: [id])
  unit            Unit                @relation(fields: [unitId], references: [id])
  manager         Manager?            @relation("ManagerSellers", fields: [managerId], references: [id])
  pendencies      Pendency[]          @relation("SellerPendencies")
  messageReturns  MessageReturn[]
  commissionRules CommissionRule[]    @relation("SellerCommissionRules")
  extracts        CommissionExtract[]
  deals           Deal[]

  positionId String?
  position   Position? @relation("SellerPosition", fields: [positionId], references: [id])

  @@index([positionId])
  @@map("sellers")
}

model Manager {
  id                    String   @id @default(cuid())
  userId                String   @unique
  fullName              String
  cpf                   String?  @unique
  whatsapp              String?
  email                 String?
  unitId                String
  accessProfile         String?
  active                Boolean  @default(true)
  receivesNotifications Boolean  @default(true)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  user            User             @relation(fields: [userId], references: [id])
  unit            Unit             @relation(fields: [unitId], references: [id])
  sellers         Seller[]         @relation("ManagerSellers")
  pendencies      Pendency[]       @relation("ManagerPendencies")
  messageReturns  MessageReturn[]
  commissionRules CommissionRule[] @relation("ManagerCommissionRules")

  positionId String?
  position   Position? @relation("ManagerPosition", fields: [positionId], references: [id])

  @@index([positionId])
  @@map("managers")
}

// ═════════════════════════════════════════════════════════════════════════════
// PESSOAS — Modelo universal PF/PJ
// ═════════════════════════════════════════════════════════════════════════════

/// Modelo unificado de pessoa (PF ou PJ) — clientes, fornecedores, sócios, etc.
model Person {
  id       String     @id @default(cuid())
  tenantId String?
  type     PersonType @default(FISICA)

  // Pessoa Física
  cpf            String?
  rg             String?
  nomeMae        String?
  nomePai        String?
  dataNascimento DateTime?

  // Pessoa Jurídica
  cnpj              String?
  razaoSocial       String?
  nomeFantasia      String?
  inscricaoEstadual String?
  possuiIE          Boolean @default(false)

  // Sócio administrador (PJ)
  socioAdmCpf      String?
  socioAdmNome     String?
  socioAdmNomeMae  String?
  socioAdmEmail    String?
  socioAdmPhone    String?
  socioAdmWhatsapp Boolean  @default(false)
  socioAdmCota     Decimal? @db.Decimal(5, 2)

  // Compartilhados
  nomeCompleto String // nome completo ou razão social para exibição
  email        String?
  phone        String?
  whatsapp     Boolean @default(false)

  // Endereço
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customers Customer[]
  deals     Deal[]     @relation("DealCustomerPerson")

  @@index([tenantId])
  @@index([cpf])
  @@index([cnpj])
  @@index([nomeCompleto])
  @@map("persons")
}

// ═════════════════════════════════════════════════════════════════════════════
// CLIENTES & VEÍCULOS & CONTRATOS
// ═════════════════════════════════════════════════════════════════════════════

model Customer {
  id        String   @id @default(cuid())
  tenantId  String?
  personId  String? // vínculo com Person (modelo universal)
  name      String
  cpf       String?
  phone     String?
  email     String?
  address   String?
  city      String?
  state     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  person     Person?    @relation(fields: [personId], references: [id])
  vehicles   Vehicle[]
  contracts  Contract[]
  pendencies Pendency[]
  deals      Deal[]

  @@index([tenantId])
  @@index([cpf])
  @@index([name])
  @@map("customers")
}

model Vehicle {
  id       String  @id @default(cuid())
  tenantId String?
  unitId   String? // unidade/revenda responsável

  // Identificação
  plate   String?
  chassi  String?
  renavam String?

  // Descrição
  brand        String?
  model        String?
  version      String? // versão/trim (ex: "Sport 2.0 4x4 Turbo")
  year         Int? // ano de fabricação (campo legado mantido)
  modelYear    Int? // ano do modelo
  color        String?
  fuel         String? // GASOLINA, ETANOL, FLEX, DIESEL, ELETRICO, HIBRIDO
  transmission String? // MANUAL, AUTOMATICO, CVT, SEMI_AUTOMATICO
  doors        Int?
  km           Int?

  // Classificação
  vehicleType   VehicleType?
  conditionType VehicleCondition?

  // Estoque
  stockType     VehicleStockType?
  stockLocation VehicleStockLocation?
  stockStatus   VehicleStockStatus?   @default(DISPONIVEL)

  // Especificações técnicas extras
  engine       String? // ex: "1.0 Turbo Flex"
  displacement String? // ex: "999 cc"
  power        String? // ex: "116 cv"
  bodyType     String? // ex: "Sedan", "SUV", "Hatch"

  // Financeiro
  salePrice          Decimal? @db.Decimal(12, 2)
  purchasePrice      Decimal? @db.Decimal(12, 2)
  fipeValue          Decimal? @db.Decimal(12, 2)
  fipeCode           String? // código FIPE ex: "005415-6"
  fipeReferenceMonth String? // ex: "maio/2026"

  // ── Precificação de venda (gerente+ define APÓS aprovação da avaliação) ──
  promoPrice         Decimal?  @db.Decimal(12, 2)
  isPromo            Boolean   @default(false)
  promoStartsAt      DateTime?
  promoEndsAt        DateTime?
  isAvailableForSale Boolean   @default(false)
  pricingNotes       String?
  pricedById         String?
  pricedAt           DateTime?

  // Cautelar/perícia
  cautelarStatus CautelarStatus? @default(SEM_CAUTELAR)
  cautelarNumber String?
  cautelarNotes  String?

  // Mídia
  mainPhotoUrl String?

  // Origem
  originEvaluationId String? // avaliação que originou este cadastro

  // Meta
  active     Boolean   @default(true)
  entryDate  DateTime? // data de entrada no estoque
  exitDate   DateTime? // data de saída do estoque
  notes      String?
  customerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  unit            Unit?                   @relation("UnitStockVehicles", fields: [unitId], references: [id])
  customer        Customer?               @relation(fields: [customerId], references: [id])
  contracts       Contract[]
  pendencies      Pendency[] // pendências de atendimento (modelo existente)
  dealVehicles    DealVehicle[]
  photos          VehiclePhoto[]
  evaluations     VehicleEvaluation[]
  stockPendencies VehicleStockPendency[] // pendências de estoque configuráveis
  pricingHistory  VehiclePricingHistory[]

  @@index([tenantId])
  @@index([unitId])
  @@index([plate])
  @@index([stockStatus])
  @@index([stockLocation])
  @@index([brand, model])
  @@map("vehicles")
}

// ── Histórico de precificação de venda ────────────────────────────────────────

model VehiclePricingHistory {
  id             String   @id @default(cuid())
  vehicleId      String
  tenantId       String?
  changedById    String
  action         String // SET_PRICE | UPDATE_PRICE | PROMO_START | PROMO_END | AVAILABILITY_ON | AVAILABILITY_OFF | NOTES_UPDATE
  oldSalePrice   Decimal? @db.Decimal(12, 2)
  newSalePrice   Decimal? @db.Decimal(12, 2)
  oldPromoPrice  Decimal? @db.Decimal(12, 2)
  newPromoPrice  Decimal? @db.Decimal(12, 2)
  oldIsAvailable Boolean?
  newIsAvailable Boolean?
  oldIsPromo     Boolean?
  newIsPromo     Boolean?
  reason         String?
  createdAt      DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([tenantId])
  @@map("vehicle_pricing_history")
}

// ── Fotos do veículo ──────────────────────────────────────────────────────────

model VehiclePhoto {
  id        String   @id @default(cuid())
  vehicleId String
  url       String
  caption   String?
  order     Int      @default(0)
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_photos")
}

// ── Avaliação de veículo ──────────────────────────────────────────────────────

/// Avaliações realizadas antes de compra/troca/consignação
model VehicleEvaluation {
  id        String  @id @default(cuid())
  tenantId  String?
  unitId    String?
  vehicleId String? // preenchido se aprovado e adicionado ao estoque

  // Dados do veículo na avaliação
  plate           String?
  brand           String?
  model           String?
  version         String?
  manufactureYear Int?
  modelYear       Int?
  km              Int?
  color           String?
  fuel            String?
  transmission    String?
  chassi          String?
  renavam         String?
  vehicleType     VehicleType?
  conditionType   VehicleCondition?

  // Specs extras capturadas na avaliação
  doors        Int?
  engine       String? // motorização ex: "1.0 Turbo"
  displacement String? // cilindradas ex: "999 cc"
  power        String? // potência ex: "116 cv"
  bodyType     String? // carroceria ex: "Sedan"

  // FIPE
  fipeCode           String?
  fipeReferenceMonth String?

  // Dados da avaliação
  fipeValue          Decimal?            @db.Decimal(12, 2) // FIPE consultada
  evaluatedValue     Decimal?            @db.Decimal(12, 2) // valor avaliado pelo avaliador
  desiredValue       Decimal?            @db.Decimal(12, 2) // valor desejado pelo proprietário
  minimumValue       Decimal?            @db.Decimal(12, 2) // mínimo aceitável para compra
  suggestedSalePrice Decimal?            @db.Decimal(12, 2) // sugestão de preço de venda
  stockType          VehicleStockType? // tipo de estoque pós-aprovação
  evaluationNotes    String?
  result             EvaluationResult    @default(PENDENTE)
  intention          EvaluationIntention @default(APENAS_AVALIACAO)

  // Rastreabilidade da consulta por placa
  lookupSource  String? // "internal_cache" | "authorized_provider" | "manual"
  lookupDataRaw Json? // payload bruto retornado pelo provedor

  // Cautelar
  cautelarStatus CautelarStatus?
  cautelarNumber String?
  cautelarNotes  String?

  // Dados do proprietário/cliente
  ownerName  String?
  ownerCpf   String?
  ownerPhone String?
  ownerEmail String?
  ownerNotes String?

  // Pendências identificadas
  pendencyNotes String?

  // Meta
  evaluatedById String?
  evaluatedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // ── Submissão para aprovação / Cancelamento / Liberação ──────────────────
  // Marca o momento em que o avaliador envia a avaliação para o gerente
  // (status passa a AGUARDANDO_APROVACAO). O gerente então precifica e libera
  // — `releasedAt` indica liberação, `cancelledAt` indica cancelamento.
  approvalRequestedAt   DateTime?
  approvalRequestedById String?
  releasedAt            DateTime?
  releasedByUserId      String?
  cancelledAt           DateTime?
  cancelledById         String?
  cancelReason          String?

  // ── Reformulação Avaliação completa (etapas, gastos, integração) ─────────
  // Status de workflow paralelo ao `result`: DRAFT | IN_PROGRESS |
  // AGUARDANDO_APROVACAO | LIBERADA | PENDING_REVIEW | FINALIZED |
  // APPROVED | REJECTED | REOPENED | CANCELADA
  status            String?  @default("DRAFT")
  /// Soma de todos os EvaluationService.estimatedCost (cache calculado no save)
  totalExpenses     Decimal? @default(0) @db.Decimal(12, 2)
  /// Previsão de dias para realizar os serviços
  estimatedDays     Int?
  /// Feedback final do avaliador no Resumo
  evaluatorFeedback String?
  /// Vínculo com Deal (negociação) quando aplicável
  negotiationId     String?
  /// Para test-drive: usuário realizou? Observações opcionais
  testDriveDone     Boolean? @default(false)

  // ── Decisão do cliente sobre a proposta ───────────────────────────────────
  /// PENDENTE (default) | ACEITA | RECUSADA | ANALISANDO | EXPIRADA | CANCELADA
  customerDecision     String?   @default("PENDENTE")
  customerDecisionAt   DateTime?
  customerDecisionById String?
  /// Motivo/observação da decisão (especialmente quando RECUSADA)
  customerDecisionNote String?

  // ── Disponibilidade operacional (definida pelo gerente+) ──────────────────
  /// Lista CSV das operações em que o veículo pode entrar: "COMPRA,TROCA,CONSIGNACAO"
  /// Default null = nenhuma. O gerente define no momento da liberação.
  availableFor       String?
  /// Validade da proposta — se vencer, customerDecision vira EXPIRADA na próxima leitura.
  proposalValidUntil DateTime?

  // Relations
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  unit        Unit?    @relation("UnitEvaluations", fields: [unitId], references: [id])
  evaluatedBy User?    @relation("EvaluatedByUser", fields: [evaluatedById], references: [id])

  @@index([tenantId])
  @@index([vehicleId])
  @@index([unitId])
  @@index([result])
  @@index([status])
  @@index([negotiationId])
  @@index([createdAt])
  @@map("vehicle_evaluations")
}

// ── Opções de pendências de estoque (configuráveis) ───────────────────────────

/// Categorias de pendência configuráveis pelo MASTER (global) ou ADM (tenant)
model StockPendencyOption {
  id              String   @id @default(cuid())
  tenantId        String? // null = global (MASTER), preenchido = tenant-specific (ADM)
  label           String // nome exibido no filtro e nos cards
  description     String?
  category        String? // DOCUMENTACAO, PREPARACAO, AVALIACAO, FINANCEIRO, OUTROS
  active          Boolean  @default(true)
  createdByMaster Boolean  @default(false) // MASTER criou → ADM não pode excluir/desativar
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  vehicleStockPendencies VehicleStockPendency[]

  @@index([tenantId])
  @@index([active])
  @@map("stock_pendency_options")
}

// ── Pendências de estoque aplicadas ao veículo ────────────────────────────────

model VehicleStockPendency {
  id           String    @id @default(cuid())
  vehicleId    String
  optionId     String
  notes        String?
  resolved     Boolean   @default(false)
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  vehicle    Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  option     StockPendencyOption @relation(fields: [optionId], references: [id])
  resolvedBy User?               @relation("ResolvedStockPendencies", fields: [resolvedById], references: [id])

  @@unique([vehicleId, optionId])
  @@index([vehicleId])
  @@index([optionId])
  @@map("vehicle_stock_pendencies")
}

model Contract {
  id              String       @id @default(cuid())
  tenantId        String?
  number          String?
  type            ContractType @default(VENDA)
  customerId      String?
  vehicleId       String?
  sellerId        String?
  managerId       String?
  unitId          String?
  saleValue       Decimal?     @db.Decimal(12, 2)
  financedValue   Decimal?     @db.Decimal(12, 2)
  bank            String?
  returnRate      Decimal?     @db.Decimal(5, 3)
  warrantyValue   Decimal?     @db.Decimal(10, 2)
  warrantyProduct String?
  docValue        Decimal?     @db.Decimal(10, 2)
  saleDate        DateTime?
  status          String?      @default("ATIVO")
  pdfPath         String?
  notes           String?
  rawData         Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  customer        Customer?               @relation(fields: [customerId], references: [id])
  vehicle         Vehicle?                @relation(fields: [vehicleId], references: [id])
  parseResults    ContractParseResult[]
  commissionCalcs CommissionCalculation[]
  pendencies      Pendency[]

  dealId String?
  deal   Deal?   @relation("DealContracts", fields: [dealId], references: [id])

  @@index([tenantId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([sellerId])
  @@index([saleDate])
  @@index([dealId])
  @@map("contracts")
}

model ContractParseResult {
  id               String    @id @default(cuid())
  contractId       String?
  pdfOriginalName  String
  pdfPath          String?
  parsedData       Json
  extractedFields  Json?
  validationErrors Json?
  status           String    @default("PENDENTE")
  reviewedById     String?
  reviewedAt       DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  contract   Contract? @relation(fields: [contractId], references: [id])
  reviewedBy User?     @relation(fields: [reviewedById], references: [id])

  @@index([contractId])
  @@index([status])
  @@map("contract_parse_results")
}

// ═════════════════════════════════════════════════════════════════════════════
// NEGOCIAÇÕES — Módulo de vendas, compras, trocas e consignações
// ═════════════════════════════════════════════════════════════════════════════

/// Negociação — unidade central do módulo comercial
model Deal {
  id         String     @id @default(cuid())
  dealNumber String? // número legível da negociação (ex: NEG-2026-001)
  tenantId   String?
  unitId     String?
  sellerId   String?
  managerId  String? // gerente responsável (User.id)
  customerId String? // Customer vinculado
  personId   String? // Person universal PF/PJ
  type       DealType   @default(VENDA)
  status     DealStatus @default(RASCUNHO)
  source     String?    @default("MANUAL") // MANUAL, PLANILHA, API

  // ── Valores financeiros expandidos ───────────────────────────────────────
  saleAmount       Decimal? @db.Decimal(12, 2) // valor de venda
  purchaseAmount   Decimal? @db.Decimal(12, 2) // valor de compra
  financedAmount   Decimal? @db.Decimal(12, 2) // valor financiado
  documentationFee Decimal? @db.Decimal(12, 2) // taxa de documentação
  documentationPaidBy String? // LOJA | CLIENTE (loja paga = cortesia, sem comissão)
  warrantyPaidBy String? // LOJA | CLIENTE — quem paga a garantia (loja paga = cortesia)
  signalAmount     Decimal? @db.Decimal(12, 2) // sinal / entrada
  payoffAmount     Decimal? @db.Decimal(12, 2) // quitação do veículo recebido
  discountAmount   Decimal? @db.Decimal(12, 2) // desconto concedido
  servicesAmount   Decimal? @db.Decimal(12, 2) // total de serviços adicionais
  marginAmount     Decimal? @db.Decimal(12, 2) // margem calculada
  paymentBank      String? // banco/financeira
  paymentType      String? // ENTRADA, FINANCIAMENTO, PIX, DINHEIRO, CARTAO, MISTO

  // ── Retorno financeiro (etapa de financiamento) ──────────────────────────
  // financedAmount (acima) = valor financiado / base do retorno.
  returnRatePercent      Decimal?         @db.Decimal(5, 2) // % informado pelo vendedor (0–6)
  returnGrossValue       Decimal?         @db.Decimal(12, 2) // financedAmount * returnRatePercent/100
  ilaPercent             Decimal?         @db.Decimal(7, 4) // restrito a perfis autorizados
  ilaValue               Decimal?         @db.Decimal(12, 2) // returnGrossValue * ilaPercent/100
  iofPercent             Decimal?         @db.Decimal(7, 4) // restrito a perfis autorizados
  iofValue               Decimal?         @db.Decimal(12, 2) // returnGrossValue * iofPercent/100
  returnNetValue         Decimal?         @db.Decimal(12, 2) // bruto - ILA - IOF (base da comissão)
  returnCommissionStatus CommissionStatus @default(PREVISTO)

  // ── Consignação ──────────────────────────────────────────────────────────
  consignMinValue Decimal?  @db.Decimal(12, 2) // valor mínimo aceito
  consignCommPct  Decimal?  @db.Decimal(6, 4) // comissão da loja (%)
  consignDeadline DateTime? // prazo da consignação

  // ── Valores de resumo (calculados no save) — mantidos para compatibilidade
  vehicleValue  Decimal? @db.Decimal(12, 2)
  tradeValue    Decimal? @db.Decimal(12, 2)
  totalDebts    Decimal? @db.Decimal(12, 2)
  totalPayments Decimal? @db.Decimal(12, 2)
  balance       Decimal? @db.Decimal(12, 2)
  changeAmount  Decimal? @db.Decimal(12, 2) // troco

  // ── Troco — destinatário ─────────────────────────────────────────────────
  changeBeneficiary    String?
  changeBeneficiaryCpf String?
  changeBank           String?
  changeAgency         String?
  changeAccount        String?
  changePix            String?

  // ── Aprovação / Rejeição ─────────────────────────────────────────────────
  approvalNotes String?
  approvedById  String? // User.id de quem aprovou/rejeitou
  approvedAt    DateTime?

  // ── Datas operacionais ───────────────────────────────────────────────────
  deliveryDate    DateTime? // data prevista de entrega
  finalizedAt     DateTime? // quando foi finalizada
  cancelledAt     DateTime? // quando foi cancelada
  cancelledById   String? // User.id de quem cancelou
  cancelledReason String? // motivo obrigatório do cancelamento

  // ── Controle de notificação ──────────────────────────────────────────────
  notificationSentAt DateTime?

  // ── Legado (mantido para compatibilidade) ────────────────────────────────
  releasedAt       DateTime?
  releasedByUserId String?
  recusedAt        DateTime?
  recusedByUserId  String?
  recusedReason    String?

  notes String?

  // ── Importação de planilha ───────────────────────────────────────────────
  externalId          String?
  saleDate            DateTime?
  sellerNameFromSheet String?
  isSellerProvisional Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant           Tenant?               @relation(fields: [tenantId], references: [id])
  seller           Seller?               @relation(fields: [sellerId], references: [id])
  customer         Customer?             @relation(fields: [customerId], references: [id])
  person           Person?               @relation("DealCustomerPerson", fields: [personId], references: [id])
  manager          User?                 @relation("DealManager", fields: [managerId], references: [id])
  vehicles         DealVehicle[]
  debts            DealDebt[]
  payments         DealPayment[]
  services         DealService[]
  warrantySales    WarrantySale[]
  history          DealStatusHistory[]
  auditLogs        DealAuditLog[]
  releaseRequests  DealReleaseRequest[]
  appointments     Appointment[]
  pendencies       Pendency[]            @relation("DealPendencies")
  contracts        Contract[]            @relation("DealContracts")
  sheetImportRows  SheetImportRow[]      @relation("DealSheetRows")
  discountRequests DealDiscountRequest[]
  changes          DealChange[]
  reopenLogs       DealReopenLog[]
  attachments      DealAttachment[]
  documents        DealDocument[]
  financeProposals FinanceProposal[]     @relation("DealFinanceProposals")
  returnSnapshots  ReturnCalculationSnapshot[]

  @@index([tenantId])
  @@index([unitId])
  @@index([sellerId])
  @@index([managerId])
  @@index([status])
  @@index([type])
  @@index([externalId])
  @@index([dealNumber])
  @@map("deals")
}

/// Veículo envolvido na negociação (vendido, trocado, comprado, consignado)
model DealVehicle {
  id             String   @id @default(cuid())
  dealId         String
  vehicleId      String?
  role           String // VENDIDO, TROCA, COMPRADO, CONSIGNADO
  plate          String?
  brand          String?
  model          String?
  year           Int?
  color          String?
  chassi         String?
  renavam        String?
  km             Int? // quilometragem
  condition      String? // OTIMO, BOM, REGULAR, RUIM
  agreedValue    Decimal? @db.Decimal(12, 2) // valor acordado na negociação
  evaluatedValue Decimal? @db.Decimal(12, 2) // valor avaliado
  fipeValue      Decimal? @db.Decimal(12, 2) // valor FIPE
  hasFinancing   Boolean  @default(false) // tem financiamento ativo?
  payoffValue    Decimal? @db.Decimal(12, 2) // valor de quitação
  payoffBank     String? // banco da quitação
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  deal    Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([dealId])
  @@index([dealId, role])
  @@map("deal_vehicles")
}

/// Serviços adicionais vinculados à negociação
model DealService {
  id         String   @id @default(cuid())
  dealId     String
  name       String // ex: Garantia, Vitrificação, Insulfilm, Higienização…
  value      Decimal  @db.Decimal(12, 2) // valor cobrado do cliente
  cost       Decimal? @db.Decimal(12, 2) // custo para a loja
  supplier   String? // fornecedor
  commission Decimal? @db.Decimal(12, 2) // comissão sobre o serviço
  notes      String?
  createdAt  DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("deal_services")
}

/// Auditoria detalhada (campo a campo) de ações nas negociações
model DealAuditLog {
  id        String   @id @default(cuid())
  dealId    String
  tenantId  String?
  unitId    String?
  userId    String?
  userName  String?
  userRole  String?
  action    String // CRIAR, EDITAR, APROVAR, REJEITAR, CANCELAR, FINALIZAR, STATUS, etc.
  field     String? // campo alterado (ex: "status", "saleAmount")
  oldValue  String? // valor anterior (serializado)
  newValue  String? // valor novo (serializado)
  reason    String? // motivo informado
  metadata  Json? // dados extras estruturados
  createdAt DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([tenantId])
  @@index([action])
  @@map("deal_audit_logs")
}

model ReturnCalculationSnapshot {
  id                   String   @id @default(cuid())
  tenantId             String
  negotiationId        String
  financingId          String?
  baseAmount           Decimal  @db.Decimal(14, 2)
  returnPercent        Decimal  @db.Decimal(7, 4)
  returnMinPercent     Decimal  @db.Decimal(7, 4)
  returnMaxPercent     Decimal  @db.Decimal(7, 4)
  grossReturnAmount    Decimal  @db.Decimal(14, 2)
  ilaSettingId         String?
  ilaCompetenceMonth   Int?
  ilaCompetenceYear    Int?
  ilaPercent           Decimal? @db.Decimal(7, 4)
  ilaDiscountAmount    Decimal  @db.Decimal(14, 2)
  iofRuleId            String?
  iofStartDate         DateTime?
  iofEndDate           DateTime?
  iofPercent           Decimal? @db.Decimal(7, 4)
  iofDiscountAmount    Decimal  @db.Decimal(14, 2)
  netReturnAmount      Decimal  @db.Decimal(14, 2)
  commissionBaseAmount Decimal  @db.Decimal(14, 2) @default(0)
  operationDate        DateTime
  status               String   @default("CALCULADO")
  calculatedBy         String?
  calculatedAt         DateTime @default(now())
  settingsVersion      String?
  snapshotJson         Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  deal Deal @relation(fields: [negotiationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([negotiationId])
  @@index([calculatedAt])
  @@map("return_calculation_snapshots")
}

/// Débito do veículo envolvido na negociação
model DealDebt {
  id          String    @id @default(cuid())
  dealId      String
  vehicleRole String? // VENDIDO ou TROCA
  type        String // MULTA, IPVA, LICENCIAMENTO, FINANCIAMENTO, etc.
  description String?
  value       Decimal   @db.Decimal(12, 2)
  dueDate     DateTime?
  responsavel String? // quem paga: COMPRADOR, VENDEDOR, LOJA
  notes       String?
  createdAt   DateTime  @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("deal_debts")
}

/// Forma de pagamento da negociação
model DealPayment {
  id                      String    @id @default(cuid())
  dealId                  String
  tenantId                String?
  type                    String // DINHEIRO, PIX, CARTAO_DEBITO, CARTAO_CREDITO, FINANCIAMENTO, BOLETO, TRANSFERENCIA, SINAL, DUPLICATA, OUTROS
  status                  String? // PENDENTE | CONFIRMADO | CANCELADO (default PENDENTE)
  value                   Decimal   @db.Decimal(12, 2)
  bank                    String?
  cardBrand               String? // VISA, MASTER, ELO, AMEX, HIPERCARD, OUTROS
  pixKey                  String?
  agency                  String?
  account                 String?
  installments            Int?
  /**
   * Valor da parcela cadastrado manualmente (vindo da financeira).
   */
  installmentValue        Decimal?  @db.Decimal(12, 2)
  /**
   * Prazo entre parcelas em dias (30, 60...).
   */
  installmentIntervalDays Int?
  /**
   * Retorno da financeira em % (0,10–6,00). Cadastra-se F&I/gerente/financeiro.
   */
  returnPct               Decimal?  @db.Decimal(4, 2)
  /**
   * Placa do veículo identificadora — útil pra negociações em lote multi-veículo.
   */
  vehiclePlate            String?
  firstDueDate            DateTime?
  dueDate                 DateTime?
  paidAt                  DateTime?
  notes                   String?
  createdById             String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime? @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([tenantId])
  @@map("deal_payments")
}

// ── Solicitação de desconto ──────────────────────────────────────────────────

enum DiscountRequestStatus {
  PENDENTE
  APROVADO
  RECUSADO
  CANCELADO
}

model DealDiscountRequest {
  id             String                @id @default(cuid())
  dealId         String
  tenantId       String?
  requestedById  String
  requestedValue Decimal               @db.Decimal(12, 2)
  approvedValue  Decimal?              @db.Decimal(12, 2)
  reason         String
  status         DiscountRequestStatus @default(PENDENTE)
  decidedById    String?
  decidedAt      DateTime?
  decisionNote   String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([tenantId])
  @@index([status])
  @@map("deal_discount_requests")
}

// ── Troco (changeAmount destinatário detalhado) ──────────────────────────────

model DealChange {
  id          String   @id @default(cuid())
  dealId      String
  tenantId    String?
  value       Decimal  @db.Decimal(12, 2)
  beneficiary String
  document    String?
  bank        String?
  agency      String?
  account     String?
  pixKey      String?
  reason      String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([tenantId])
  @@map("deal_changes")
}

// ── Reabertura de negociação ────────────────────────────────────────────────

model DealReopenLog {
  id             String   @id @default(cuid())
  dealId         String
  tenantId       String?
  reopenedById   String
  reason         String
  previousStatus String
  createdAt      DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([tenantId])
  @@map("deal_reopen_logs")
}

/// Categoria de anexo da negociação (comprovantes, NFe, contrato assinado, etc).
enum DealAttachmentCategory {
  COMPROVANTE_PAGAMENTO
  COMPROVANTE_QUITACAO
  COMPROVANTE_DEBITO
  COMPROVANTE_TROCO
  CONTRATO_ASSINADO
  PROCURACAO_ASSINADA
  NFE
  RECIBO
  OUTRO
}

/// Anexo de negociação — financeiro/back-office sobe comprovantes, contratos, NFe.
/// Pode ser vinculado a um item específico (payment/debt/payoff/change).
model DealAttachment {
  id         String                 @id @default(cuid())
  dealId     String
  tenantId   String?
  category   DealAttachmentCategory
  fileName   String
  fileType   String // image | pdf | other
  mimeType   String
  fileSize   Int?
  storageKey String
  publicUrl  String?
  notes      String?

  // Vínculos opcionais com itens financeiros da negociação
  paymentId String?
  debtId    String?
  vehicleId String? // para comprovante de quitação por veículo
  changeId  String?

  uploadedById   String?
  uploadedByName String?
  uploadedAt     DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([tenantId])
  @@index([category])
  @@index([paymentId])
  @@index([debtId])
  @@map("deal_attachments")
}

/// Categoria de template de documento.
enum DocumentTemplateType {
  CONTRATO_COMPRA
  CONTRATO_VENDA
  CONTRATO_TROCA
  CONTRATO_CONSIGNACAO
  PROCURACAO
  RECIBO
  TERMO_ENTREGA
  TERMO_RESPONSABILIDADE
  OUTRO
}

/// Template de documento cadastrado pelo MASTER (global, tenantId=null) ou pelo
/// lojista (tenantId setado). Corpo HTML com merge fields tipo `{{cliente.nome}}`.
model DocumentTemplate {
  id          String               @id @default(cuid())
  tenantId    String? // null = padrão global (MASTER)
  type        DocumentTemplateType
  name        String
  description String?
  bodyHtml    String               @db.Text
  variables   Json? // lista de variáveis disponíveis (para UI de preview)
  active      Boolean              @default(true)
  isDefault   Boolean              @default(false)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents DealDocument[]

  @@index([tenantId])
  @@index([type])
  @@index([active])
  @@map("document_templates")
}

/// Documento gerado/anexado por negociação a partir de um template (ou avulso).
model DealDocument {
  id         String               @id @default(cuid())
  dealId     String
  tenantId   String?
  templateId String?
  type       DocumentTemplateType
  name       String
  bodyHtml   String?              @db.Text // HTML renderizado (snapshot do template + merge)
  pdfUrl     String? // PDF gerado (se houver)
  storageKey String?

  // Versão assinada anexada manualmente (upload pelo financeiro/cliente)
  signedFileUrl String?
  signedAt      DateTime?
  signedBy      String?

  status String @default("RASCUNHO") // RASCUNHO | GERADO | ASSINADO | ARQUIVADO

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deal     Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  template DocumentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@map("deal_documents")
}

/// Histórico de status da negociação
model DealStatusHistory {
  id              String   @id @default(cuid())
  dealId          String
  previousStatus  String?
  newStatus       String
  changedByUserId String?
  reason          String?
  createdAt       DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("deal_status_history")
}

/// Solicitação de liberação de negociação
model DealReleaseRequest {
  id          String    @id @default(cuid())
  dealId      String
  requestedBy String? // userId do vendedor
  requestedAt DateTime  @default(now())
  reviewedBy  String? // userId de quem avaliou
  reviewedAt  DateTime?
  status      String    @default("PENDENTE") // PENDENTE, LIBERADA, RECUSADA
  reason      String? // motivo se recusado
  notes       String?

  deal     Deal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReleasedByUser", fields: [reviewedBy], references: [id])

  @@index([dealId])
  @@index([status])
  @@map("deal_release_requests")
}

// ═════════════════════════════════════════════════════════════════════════════
// AGENDAMENTOS
// ═════════════════════════════════════════════════════════════════════════════

model Appointment {
  id                   String   @id @default(cuid())
  tenantId             String?
  dealId               String?
  type                 String // ENTREGA_VENDA, RECEBIMENTO_TROCA, RECEBIMENTO_COMPRA, RECEBIMENTO_CONSIGNADO, OUTRO
  title                String
  description          String?
  date                 DateTime
  durationMinutes      Int?
  location             String?
  responsavelId        String? // userId
  responsavelName      String?
  googleEventId        String? // ID no Google Calendar
  googleCalendarSynced Boolean  @default(false)
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  deal Deal? @relation(fields: [dealId], references: [id])

  @@index([tenantId])
  @@index([dealId])
  @@index([date])
  @@map("appointments")
}

// ═════════════════════════════════════════════════════════════════════════════
// SERVIÇOS & GARANTIAS
// ═════════════════════════════════════════════════════════════════════════════

model Service {
  id                String   @id @default(cuid())
  tenantId          String?
  name              String
  category          String?
  defaultValue      Decimal  @default(0) @db.Decimal(10, 2)
  defaultCommission Decimal  @default(0) @db.Decimal(10, 2)
  commissionType    String   @default("PERCENTUAL")
  active            Boolean  @default(true)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  commissionRules CommissionRule[] @relation("ServiceCommissionRules")

  @@index([tenantId])
  @@map("services")
}

model Warranty {
  id                          String   @id @default(cuid())
  tenantId                    String?
  name                        String
  provider                    String?
  // ── Campos legados (mantidos p/ compatibilidade com WarrantyRule/CommissionRule)
  defaultValue                Decimal  @default(0) @db.Decimal(10, 2)
  minValue                    Decimal  @default(0) @db.Decimal(10, 2)
  defaultCommission           Decimal  @default(0) @db.Decimal(10, 2)
  commissionType              String   @default("PERCENTUAL")
  // ── Precificação rica (valor cheio/reduzido + adicional prêmio/luxo) ───────
  coverageType                String? // ex: "150 itens"
  durationYears               Int      @default(1)
  fullPrice                   Decimal  @default(0) @db.Decimal(12, 2)
  reducedPrice                Decimal  @default(0) @db.Decimal(12, 2)
  hasPremiumAddon             Boolean  @default(false)
  premiumAddonName            String?
  premiumAddonValue           Decimal  @default(0) @db.Decimal(12, 2)
  // ── Comissões fixas por tipo de venda (configuráveis no cadastro) ──────────
  reducedSaleCommissionValue  Decimal  @default(0) @db.Decimal(12, 2)
  fullSaleCommissionValue     Decimal  @default(0) @db.Decimal(12, 2)
  premiumAddonCommissionValue Decimal  @default(0) @db.Decimal(12, 2)
  active                      Boolean  @default(true)
  notes                       String?
  createdById                 String?
  updatedById                 String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  // Relations
  commissionRules CommissionRule[] @relation("WarrantyCommissionRules")
  warrantyRules   WarrantyRule[]
  warrantySales   WarrantySale[]

  @@index([tenantId])
  @@map("warranties")
}

/// Tipo de venda da garantia
enum WarrantySaleType {
  FULL // valor cheio
  REDUCED // valor reduzido
}

/// Estado da venda da garantia
enum WarrantySaleStatus {
  ATIVA
  CANCELADA
  ESTORNADA
}

/// Registro de uma garantia vendida dentro de uma negociação.
/// O preço final e a comissão são calculados pelo service layer a partir do
/// cadastro da garantia (cheio/reduzido + adicional prêmio/luxo).
model WarrantySale {
  id                String             @id @default(cuid())
  tenantId          String?
  dealId            String
  warrantyId        String
  sellerId          String?
  saleType          WarrantySaleType
  basePrice         Decimal            @db.Decimal(12, 2) // fullPrice ou reducedPrice no momento da venda
  hasPremiumAddon   Boolean            @default(false)
  premiumAddonValue Decimal            @default(0) @db.Decimal(12, 2)
  finalPrice        Decimal            @db.Decimal(12, 2) // basePrice + (premium? premiumAddonValue : 0)
  status            WarrantySaleStatus @default(ATIVA)
  createdBy         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  deal     Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  warranty Warranty @relation(fields: [warrantyId], references: [id])

  @@index([tenantId])
  @@index([dealId])
  @@index([warrantyId])
  @@index([sellerId])
  @@map("warranty_sales")
}

// ═════════════════════════════════════════════════════════════════════════════
// PENDÊNCIAS
// ═════════════════════════════════════════════════════════════════════════════

model Pendency {
  id                String           @id @default(cuid())
  tenantId          String?
  responsibleId     String
  managerId         String?
  customerId        String?
  vehicleId         String?
  contractId        String?
  customerName      String
  plate             String?
  vehicle           String?
  negotiation       String?
  description       String?
  lead              String?
  priority          PendencyPriority @default(MEDIA)
  status            PendencyStatus   @default(ABERTA)
  type              String?
  unitId            String
  chargeRecipient   String?
  dueDate           DateTime?
  resolvedAt        DateTime?
  resolvedByUserId  String?
  lastSentAt        DateTime?
  nextSendAt        DateTime?
  totalSent         Int              @default(0)
  maxSends          Int?
  sendsPerDay       Int?
  automaticSend     Boolean          @default(false)
  frequency         String?
  allowedDays       String[]
  startTime         String?
  endTime           String?
  templateId        String?
  source            String?
  referenceMonth    String?
  // Central de Avisos — campos de severidade, SLA, atribuição e rastreamento
  severity          String? // LOW | MEDIUM | HIGH | CRITICAL (complementa priority)
  slaMinutes        Int? // tempo alvo em minutos para resolução
  slaDeadline       DateTime? // calculado: createdAt + slaMinutes
  assignedUserId    String? // usuário designado para tratar
  originModule      String? // DEALS | COMMISSIONS | STOCK | CRM | WHATSAPP | MANUAL
  originRecordId    String? // ID do registro que originou a pendência
  cancelReason      String?
  reopenedAt        DateTime?
  validatedAt       DateTime? // quando foi validada como resolvida
  validatedByUserId String? // quem validou
  escalatedAt       DateTime?
  escalatedByUserId String? // quem escalou
  notes             String?
  // Vínculo com negociação (Deal)
  dealId            String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  responsible     Seller                  @relation("SellerPendencies", fields: [responsibleId], references: [id])
  manager         Manager?                @relation("ManagerPendencies", fields: [managerId], references: [id])
  unit            Unit                    @relation(fields: [unitId], references: [id])
  resolvedByUser  User?                   @relation("ResolvedByUser", fields: [resolvedByUserId], references: [id])
  assignedUser    User?                   @relation("AssignedPendencies", fields: [assignedUserId], references: [id])
  validatedByUser User?                   @relation("ValidatedPendencies", fields: [validatedByUserId], references: [id])
  escalatedByUser User?                   @relation("EscalatedByUser", fields: [escalatedByUserId], references: [id])
  customer        Customer?               @relation(fields: [customerId], references: [id])
  vehicleRef      Vehicle?                @relation(fields: [vehicleId], references: [id])
  contract        Contract?               @relation(fields: [contractId], references: [id])
  deal            Deal?                   @relation("DealPendencies", fields: [dealId], references: [id])
  template        WhatsappTemplate?       @relation(fields: [templateId], references: [id])
  statusHistory   PendencyStatusHistory[]
  notificationLogs PendencyNotificationLog[]
  messages        PendencyMessage[]
  messageReturns  MessageReturn[]
  comments        PendencyComment[]
  events          PendencyEvent[]

  @@index([tenantId])
  @@index([status])
  @@index([responsibleId])
  @@index([managerId])
  @@index([unitId])
  @@index([customerId])
  @@index([plate])
  @@index([nextSendAt])
  @@index([dueDate])
  @@index([assignedUserId])
  @@index([slaDeadline])
  @@index([originModule, originRecordId])
  @@map("pendencies")
}

model PendencyStatusHistory {
  id              String   @id @default(cuid())
  pendencyId      String
  previousStatus  String?
  newStatus       String
  changedByUserId String?
  reason          String?
  createdAt       DateTime @default(now())

  // Relations
  pendency      Pendency @relation(fields: [pendencyId], references: [id], onDelete: Cascade)
  changedByUser User?    @relation("ChangedByUser", fields: [changedByUserId], references: [id])

  @@index([pendencyId])
  @@map("pendency_status_history")
}

// Log de cada ENVIO de lembrete de pendência (push/manual/escalonamento).
model PendencyNotificationLog {
  id         String   @id @default(cuid())
  tenantId   String?
  pendencyId String
  userId     String? // destinatário (responsável) ou alvo do escalonamento
  channel    String // FCM | WEBPUSH | MANUAL | ESCALATION
  status     String // SENT | FAILED | SKIPPED
  sentCount  Int      @default(0)
  detail     String?
  createdAt  DateTime @default(now())

  pendency Pendency @relation(fields: [pendencyId], references: [id], onDelete: Cascade)

  @@index([pendencyId])
  @@index([tenantId])
  @@map("pendency_notification_logs")
}

model PendencyMessage {
  id                String              @id @default(cuid())
  pendencyId        String
  direction         MessageDirection    @default(OUTBOUND)
  channel           NotificationChannel @default(WHATSAPP)
  messageType       String?
  content           String?
  whatsappMessageId String?
  status            String?
  sentAt            DateTime?
  createdAt         DateTime            @default(now())

  // Relations
  pendency Pendency @relation(fields: [pendencyId], references: [id], onDelete: Cascade)

  @@index([pendencyId])
  @@map("pendency_messages")
}

model PendencyComment {
  id         String   @id @default(cuid())
  pendencyId String
  userId     String
  content    String
  internal   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  pendency Pendency @relation(fields: [pendencyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([pendencyId])
  @@map("pendency_comments")
}

// Timeline unificada da pendência (fonte de verdade p/ auditoria e cobranças).
// Complementa status_history/comments/notification_logs com os eventos que antes
// não tinham casa: mudança de prioridade/prazo, pop-up exibido/ignorado,
// compromisso de prazo, escalonamento e penalidade aplicada/removida.
model PendencyEvent {
  id           String    @id @default(cuid())
  tenantId     String?
  pendencyId   String
  type         String    // CREATED | STATUS_CHANGED | RESPONSE | PRIORITY_CHANGED | DUE_CHANGED | COMMITMENT | POPUP_SHOWN | POPUP_DISMISSED | ESCALATED | PENALTY_APPLIED | PENALTY_REMOVED | REMINDER_SENT | ASSIGNED
  authorId     String?   // usuário que gerou (null = sistema)
  authorName   String?   // snapshot p/ exibir sem join (autor pode sair da base)
  content      String?   @db.Text // texto livre (resposta/justificativa) ou payload
  prevStatus   String?
  newStatus    String?
  prevPriority String?
  newPriority  String?
  prevDueDate  DateTime?
  newDueDate   DateTime?
  createdAt    DateTime  @default(now())

  pendency Pendency @relation(fields: [pendencyId], references: [id], onDelete: Cascade)

  @@index([pendencyId, createdAt])
  @@index([tenantId])
  @@index([type])
  @@map("pendency_events")
}

// ═════════════════════════════════════════════════════════════════════════════
// COMISSÕES
// ═════════════════════════════════════════════════════════════════════════════

model CommissionRule {
  id             String             @id @default(cuid())
  tenantId       String?
  name           String
  description    String?
  ruleType       CommissionRuleType
  role           UserRole?
  positionId     String?
  sellerId       String?
  managerId      String?
  unitId         String?
  serviceId      String?
  warrantyId     String?
  bank           String?
  fromQuantity   Int?
  toQuantity     Int?
  fromValue      Decimal?           @db.Decimal(12, 2)
  toValue        Decimal?           @db.Decimal(12, 2)
  fixedValue     Decimal?           @db.Decimal(10, 2)
  percentage     Decimal?           @db.Decimal(7, 4)
  commissionType String             @default("PERCENTUAL")
  active         Boolean            @default(true)
  priority       Int                @default(0)
  validFrom      DateTime?
  validUntil     DateTime?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  // Relations
  seller   Seller?   @relation("SellerCommissionRules", fields: [sellerId], references: [id])
  manager  Manager?  @relation("ManagerCommissionRules", fields: [managerId], references: [id])
  unit     Unit?     @relation(fields: [unitId], references: [id])
  service  Service?  @relation("ServiceCommissionRules", fields: [serviceId], references: [id])
  warranty Warranty? @relation("WarrantyCommissionRules", fields: [warrantyId], references: [id])
  position Position? @relation(fields: [positionId], references: [id])

  @@index([tenantId])
  @@index([sellerId])
  @@index([managerId])
  @@index([unitId])
  @@index([positionId])
  @@index([ruleType])
  @@index([active])
  @@map("commission_rules")
}

model Position {
  id          String    @id @default(cuid())
  tenantId    String?
  name        String
  slug        String
  description String?
  baseRole    UserRole?
  isSystem    Boolean   @default(false)
  active      Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  commissionRules CommissionRule[]
  sellers         Seller[]         @relation("SellerPosition")
  managers        Manager[]        @relation("ManagerPosition")
  users           User[]           @relation("UserPosition")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([active])
  @@map("positions")
}

model ReturnPercentRule {
  id                  String    @id @default(cuid())
  tenantId            String?
  name                String
  percentualInformado Decimal   @db.Decimal(5, 3)
  percentualAplicado  Decimal   @db.Decimal(5, 3)
  bank                String?
  tipoRetorno         String?
  active              Boolean   @default(true)
  validFrom           DateTime?
  validUntil          DateTime?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([tenantId])
  @@index([percentualInformado])
  @@index([bank])
  @@map("return_percent_rules")
}

model WarrantyRule {
  id                 String   @id @default(cuid())
  tenantId           String?
  warrantyId         String
  name               String
  defaultValue       Decimal  @db.Decimal(10, 2)
  minValue           Decimal  @db.Decimal(10, 2)
  commissionDefault  Decimal  @db.Decimal(7, 4)
  commissionDiscount Decimal  @db.Decimal(7, 4)
  commissionType     String   @default("PERCENTUAL")
  sellerId           String?
  managerId          String?
  unitId             String?
  active             Boolean  @default(true)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  warranty Warranty @relation(fields: [warrantyId], references: [id])

  @@index([tenantId])
  @@index([warrantyId])
  @@map("warranty_rules")
}

model CommissionCalculation {
  id              String             @id @default(cuid())
  tenantId        String?
  contractId      String?
  sellerId        String?
  managerId       String?
  unitId          String?
  period          String
  ruleId          String?
  ruleType        CommissionRuleType
  description     String
  baseValue       Decimal            @db.Decimal(12, 2)
  rateApplied     Decimal?           @db.Decimal(7, 4)
  commissionValue Decimal            @db.Decimal(10, 2)
  ruleDetails     Json?
  status          CommissionStatus   @default(PREVISTO)
  approvedById    String?
  approvedAt      DateTime?
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Relations
  contract    Contract?              @relation(fields: [contractId], references: [id])
  adjustments CommissionAdjustment[]
  extracts    CommissionExtract[]

  @@index([tenantId])
  @@index([contractId])
  @@index([sellerId])
  @@index([managerId])
  @@index([period])
  @@index([status])
  @@map("commission_calculations")
}

model CommissionAdjustment {
  id            String    @id @default(cuid())
  calculationId String
  userId        String
  previousValue Decimal   @db.Decimal(10, 2)
  newValue      Decimal   @db.Decimal(10, 2)
  reason        String
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())

  // Relations
  calculation CommissionCalculation @relation(fields: [calculationId], references: [id])
  user        User                  @relation(fields: [userId], references: [id])

  @@index([calculationId])
  @@map("commission_adjustments")
}

model CommissionExtract {
  id            String           @id @default(cuid())
  tenantId      String?
  userId        String
  sellerId      String?
  unitId        String?
  calculationId String?
  period        String // YYYY-MM
  type          String // BASE, AJUSTE, GARANTIA, RETORNO, SERVICO, BONUS, DESCONTO
  referenceId   String?
  description   String?
  value         Decimal          @db.Decimal(10, 2)
  status        CommissionStatus @default(PREVISTO)
  approvedById  String?
  approvedAt    DateTime?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  user        User                   @relation(fields: [userId], references: [id])
  seller      Seller?                @relation(fields: [sellerId], references: [id])
  unit        Unit?                  @relation(fields: [unitId], references: [id])
  calculation CommissionCalculation? @relation(fields: [calculationId], references: [id])

  @@index([tenantId])
  @@index([userId, period])
  @@index([sellerId, period])
  @@index([status])
  @@map("commission_extracts")
}

// ═════════════════════════════════════════════════════════════════════════════
// NOTIFICAÇÕES
// ═════════════════════════════════════════════════════════════════════════════

model Notification {
  id        String           @id @default(cuid())
  userId    String
  tenantId  String?
  title     String
  message   String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  actionUrl String?
  metadata  Json?
  createdAt DateTime         @default(now())

  // Relations
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([tenantId])
  @@map("notifications")
}

model NotificationDelivery {
  id             String              @id @default(cuid())
  notificationId String
  userId         String
  channel        NotificationChannel
  status         NotificationStatus  @default(PENDENTE)
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  errorMessage   String?
  externalId     String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // Relations
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@index([notificationId])
  @@index([userId, channel])
  @@index([status])
  @@map("notification_deliveries")
}

model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  appWeb          Boolean  @default(true)
  appMobile       Boolean  @default(false)
  whatsapp        Boolean  @default(true)
  email           Boolean  @default(false)
  push            Boolean  @default(false)
  newPendency     Boolean  @default(true)
  pendencyUrgent  Boolean  @default(true)
  commissionPaid  Boolean  @default(true)
  systemAlerts    Boolean  @default(true)
  quietHoursStart String?
  quietHoursEnd   String?
  updatedAt       DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

