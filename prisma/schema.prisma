// CONFIGURAÇÕES & LOGS
// ═════════════════════════════════════════════════════════════════════════════

model SystemSetting {
  id              String   @id @default(cuid())
  tenantId        String? // null = configuração global da plataforma
  key             String   @unique // TODO: migrar para @@unique([tenantId, key]) quando multi-tenancy ativo
  value           String
  description     String?
  group           String?
  isPublic        Boolean  @default(false)
  updatedAt       DateTime @updatedAt
  updatedByUserId String?

  // Relations
  updatedByUser User? @relation("SettingUpdatedBy", fields: [updatedByUserId], references: [id])

  @@index([tenantId])
  @@map("system_settings")
}

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String?
  userId       String?
  userName     String?
  userRole     String?
  action       String
  entity       String
  entityId     String?
  beforeData   Json?
  afterData    Json?
  ipAddress    String?
  userAgent    String?
  status       String?  @default("SUCCESS")
  errorMessage String?
  createdAt    DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_resets")
}

// =============================================================================
// Cache de consultas por placa — evita chamadas repetidas a APIs pagas
// =============================================================================

model VehicleLookupCache {
  id        String   @id @default(cuid())
  plate     String   @unique // normalizado sem hífen, maiúsculo
  found     Boolean  @default(false)
  source    String? // "authorized_provider" | "internal_cache"
  data      Json? // VehicleLookupData normalizado
  expiresAt DateTime // TTL configurável (padrão: 30 dias)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plate])
  @@index([expiresAt])
  @@map("vehicle_lookup_cache")
}

model ApiToken {
  id          String    @id @default(cuid())
  userId      String
  tenantId    String?
  name        String
  token       String    @unique
  permissions Json?
  active      Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([tenantId])
  @@map("api_tokens")
}

// ═════════════════════════════════════════════════════════════════════════════
// PLATAFORMA — Modelos globais gerenciados pelo MASTER
// ═════════════════════════════════════════════════════════════════════════════

/// Planos da plataforma — CRUD completo via Painel Master
model Plan {
  id                   String   @id @default(cuid())
  code                 String   @unique // BASICO | PRO | VIP | CUSTOM | ENTERPRISE | etc.
  name                 String
  description          String?
  priceMonthly         Decimal? @db.Decimal(10, 2)
  priceYearly          Decimal? @db.Decimal(10, 2)
  active               Boolean  @default(true)
  // Limites padrão
  maxUsers             Int      @default(10)
  maxVehicles          Int      @default(100)
  maxUnits             Int      @default(1)
  maxStorageMb         Int      @default(1024)
  whatsappMonthly      Int      @default(1000)
  emailMonthly         Int      @default(5000)
  trialDays            Int      @default(14)
  // Recursos liberados
  allowWhiteLabel      Boolean  @default(false)
  allowCustomDomain    Boolean  @default(false)
  allowGoogleSheets    Boolean  @default(true)
  allowAdvancedReports Boolean  @default(false)
  allowApiAccess       Boolean  @default(false)
  // Módulos incluídos (lista de chaves de módulo)
  modules              String[]
  sortOrder            Int      @default(0)
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([active])
  @@map("plans")
}

/// Feature flags globais da plataforma
model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique // ex: new_evaluation_flow
  name        String
  description String?
  enabled     Boolean  @default(false) // estado global padrão
  rolloutPct  Int      @default(0) // 0-100 — rollout gradual
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantFlags TenantFeatureFlag[]

  @@map("feature_flags")
}

/// Override de feature flag por tenant
model TenantFeatureFlag {
  tenantId String
  flagKey  String
  enabled  Boolean @default(true)

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flag   FeatureFlag @relation(fields: [flagKey], references: [key], onDelete: Cascade)

  @@id([tenantId, flagKey])
  @@index([flagKey])
  @@map("tenant_feature_flags")
}

/// Modo de manutenção — pode ser global, por módulo ou por tenant
model MaintenanceMode {
  id           String    @id @default(cuid())
  active       Boolean   @default(false)
  message      String?   @db.Text
  startAt      DateTime?
  endAt        DateTime?
  scope        String    @default("GLOBAL") // GLOBAL | MODULE | TENANT
  scopeId      String? // moduleKey ou tenantId
  allowedRoles String[] // roles que ignoram manutenção (ex: MASTER)
  activatedBy  String? // userId de quem ativou
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([active])
  @@map("maintenance_modes")
}

/// Avisos internos (in-app notices) enviados pelo MASTER
model InternalNotice {
  id              String    @id @default(cuid())
  title           String
  message         String    @db.Text
  type            String    @default("INFO") // INFO | WARNING | CRITICAL | MAINTENANCE | BILLING | RELEASE
  severity        String    @default("INFO") // INFO | SUCCESS | WARNING | ERROR | CRITICAL
  priority        String    @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  status          String    @default("ACTIVE") // DRAFT | SCHEDULED | ACTIVE | PAUSED | CANCELLED | EXPIRED | ARCHIVED | DELETED
  targetType      String    @default("ALL") // ALL | ALL_TENANTS | SELECTED_TENANTS | SELECTED_UNITS | SELECTED_ROLES | SELECTED_USERS | MASTER_ONLY | ADM_ONLY | MANAGER_ONLY | SELLER_ONLY
  targetId        String? // legado: id conforme targetType original
  targetTenants   Json? // Array<string> de tenantIds
  targetUnits     Json? // Array<string> de unitIds
  targetRoles     Json? // Array<string> de roles
  targetUsers     Json? // Array<string> de userIds
  displayType     String    @default("BELL") // BELL | BANNER | MODAL | TOAST (legado)
  displayChannels Json      @default("[\"BELL\"]") // Array<BELL|BALLOON|BANNER|MODAL|DASHBOARD>
  startsAt        DateTime  @default(now())
  endsAt          DateTime?
  required        Boolean   @default(false)
  dismissible     Boolean   @default(true)
  blockUntilRead  Boolean   @default(false)
  allowComments   Boolean   @default(false)
  actionUrl       String?
  actionLabel     String?
  createdBy       String // userId do MASTER
  updatedById     String?
  active          Boolean   @default(true) // legado — mantido para compat.
  publishedAt     DateTime?
  pausedAt        DateTime?
  cancelledAt     DateTime?
  archivedAt      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  reads InternalNoticeRead[]
  logs  InternalNoticeLog[]

  @@index([status])
  @@index([active])
  @@index([targetType, targetId])
  @@index([startsAt, endsAt])
  @@map("internal_notices")
}

/// Controle de leitura e confirmação de avisos internos
model InternalNoticeRead {
  id          String    @id @default(cuid())
  noticeId    String
  userId      String
  displayedAt DateTime?
  readAt      DateTime  @default(now())
  clickedAt   DateTime?
  dismissed   Boolean   @default(false)
  confirmed   Boolean   @default(false)

  notice InternalNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@unique([noticeId, userId])
  @@index([noticeId])
  @@index([userId])
  @@map("internal_notice_reads")
}

/// Auditoria completa de ações sobre avisos internos
model InternalNoticeLog {
  id        String   @id @default(cuid())
  noticeId  String
  userId    String?
  action    String // CREATED | EDITED | PUBLISHED | SCHEDULED | PAUSED | RESUMED | CANCELLED | ARCHIVED | DELETED | DUPLICATED | TESTED | READ | CLICKED | DISMISSED | EXPIRED
  success   Boolean  @default(true)
  details   Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  notice InternalNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@index([noticeId, createdAt])
  @@index([action])
  @@map("internal_notice_logs")
}

/// Sessões de impersonation — auditoria obrigatória
model ImpersonationSession {
  id             String    @id @default(cuid())
  masterId       String // MASTER executando a impersonation
  targetUserId   String // usuário alvo
  targetTenantId String? // tenant do usuário alvo
  reason         String // motivo obrigatório
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  ipAddress      String?
  userAgent      String?

  @@index([masterId])
  @@index([targetUserId])
  @@index([startedAt])
  @@map("impersonation_sessions")
}

// ═════════════════════════════════════════════════════════════════════════════
// IDENTIDADE GLOBAL DO SISTEMA — gerenciada pelo MASTER
// ═════════════════════════════════════════════════════════════════════════════

/// Identidade visual e institucional global da plataforma (singleton)
model SystemIdentity {
  id             String   @id @default(cuid())
  systemName     String   @default("AutoDrive")
  systemSlogan   String?
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String   @default("#166534")
  secondaryColor String?
  accentColor    String?
  footerText     String?
  supportEmail   String?
  supportPhone   String?
  supportUrl     String?
  termsUrl       String?
  privacyUrl     String?
  customDomain   String? // domínio padrão da plataforma
  timezone       String   @default("America/Sao_Paulo")
  locale         String   @default("pt-BR")
  currency       String   @default("BRL")
  updatedById    String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@map("system_identity")
}

// ═════════════════════════════════════════════════════════════════════════════
// CREDENCIAIS DE INTEGRAÇÃO — gerenciadas pelo MASTER
// ═════════════════════════════════════════════════════════════════════════════

/// Credenciais de APIs externas controladas pelo MASTER
model IntegrationCredential {
  id            String    @id @default(cuid())
  service       String // FIPE | PLATE_LOOKUP | RENAVAM | CNPJ_LOOKUP | CEP | STORAGE | PAYMENT | DIGITAL_SIGN | OTHER
  name          String // nome amigável
  description   String?
  apiUrl        String?
  apiKey        String? // ⚠️ sensível
  apiSecret     String? // ⚠️ sensível
  token         String? // ⚠️ sensível
  username      String?
  webhookSecret String? // ⚠️ sensível
  active        Boolean   @default(true)
  isDefault     Boolean   @default(false) // credencial padrão para o serviço
  lastTestedAt  DateTime?
  lastTestOk    Boolean   @default(false)
  lastTestMsg   String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?

  @@index([service])
  @@index([active])
  @@map("integration_credentials")
}

// ═════════════════════════════════════════════════════════════════════════════
// CATÁLOGOS PERSISTENTES — Bancos (BrasilAPI)
// ═════════════════════════════════════════════════════════════════════════════

/// Catálogo de bancos brasileiros — espelho persistente da BrasilAPI.
/// Permite consultas offline e sobrevive a restart sem hit na API externa.
/// Atualizado via /api/integrations/brasilapi/banks?refresh=1 (MASTER/ADM).
model Bank {
  id        String   @id @default(cuid())
  /// Código compe (3 dígitos). Pode ser nulo (ISPB-only).
  code      Int?
  /// Identificador único oficial (ISPB) — 8 dígitos.
  ispb      String   @unique
  name      String
  fullName  String?
  active    Boolean  @default(true)
  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([active])
  @@map("banks")
}

/// Cache persistente de respostas FIPE (provider Parallelum).
/// `cacheKey` é um identificador único por endpoint + parâmetros.
/// `expiresAt` é consultado pelo service para decidir se reaproveita ou refresca.
model FipeCache {
  id          String   @id @default(cuid())
  provider    String   @default("parallelum")
  cacheKey    String   @unique
  endpoint    String // references | brands | models | years | price | priceByCode
  vehicleType String? // cars | motorcycles | trucks
  brandId     String?
  modelId     String?
  yearId      String?
  codeFipe    String?
  reference   String? // mês/ano referência da tabela FIPE
  data        Json
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([provider])
  @@index([endpoint])
  @@index([vehicleType])
  @@index([expiresAt])
  @@map("fipe_cache")
}

// ═════════════════════════════════════════════════════════════════════════════
// AVALIAÇÃO DE VEÍCULOS — Item / Service / Attachment / History
// Estende o modelo VehicleEvaluation existente sem alterá-lo.
// ═════════════════════════════════════════════════════════════════════════════

/// Item individual de checklist dentro de uma avaliação.
/// Exemplo: "Banco motorista" da seção "INTERIOR".
model EvaluationItem {
  id            String   @id @default(cuid())
  tenantId      String?
  evaluationId  String
  section       String // INTERIOR | FRENTE | DIREITA | TRASEIRA | ESQUERDA | TEST_DRIVE | DOCUMENTOS | SERVICOS
  catalogKey    String? // chave canônica do catálogo (ex: "interior.banco_motorista")
  name          String
  status        String   @default("PENDING") // PENDING | CONFORME | ATENCAO | REPARO | OBRIGATORIO | NA | REAVALIAR
  priority      String? // BAIXA | MEDIA | ALTA | URGENTE
  notes         String?
  totalExpenses Decimal? @default(0) @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  services    EvaluationService[]
  attachments EvaluationAttachment[]
  history     EvaluationHistory[]

  @@index([evaluationId])
  @@index([evaluationId, section])
  @@index([catalogKey])
  @@map("evaluation_items")
}

/// Serviço associado a um item (ou solto, com itemId=null para serviços gerais).
model EvaluationService {
  id            String   @id @default(cuid())
  tenantId      String?
  evaluationId  String
  itemId        String? // null = serviço geral da avaliação
  section       String? // copiado do item, ou GERAL
  description   String
  serviceType   String // PINTURA | FUNILARIA | POLIMENTO | HIGIENIZACAO | MECANICA | ... | OUTRO
  estimatedCost Decimal? @default(0) @db.Decimal(12, 2)
  actualCost    Decimal? @db.Decimal(12, 2)
  priority      String?
  status        String   @default("PREDICTED") // PREDICTED | APPROVED | IN_PROGRESS | DONE | CANCELED
  responsibleId String? // userId responsável sugerido
  notes         String?
  createdAt     DateTime @default(now())
  createdById   String?
  updatedAt     DateTime @updatedAt

  item EvaluationItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([evaluationId])
  @@index([itemId])
  @@index([status])
  @@map("evaluation_services")
}

/// Anexo (foto/PDF/documento) de uma avaliação.
/// Pode estar ligado a um item, a um serviço, ou solto na avaliação.
model EvaluationAttachment {
  id             String   @id @default(cuid())
  tenantId       String
  evaluationId   String
  itemId         String?
  serviceId      String?
  section        String? // INTERIOR | FRENTE | DOCUMENTOS | ...
  category       String? // CRLV | ATPV_E | DUT_CRV | LAUDO_CAUTELAR | COMPROVANTE | CNH | FOTO | OUTRO
  fileName       String
  fileType       String // image | pdf | other
  mimeType       String
  fileSize       Int?
  storageKey     String // chave no storage (path local ou S3 key)
  publicUrl      String?
  uploadedById   String?
  uploadedByName String?
  createdAt      DateTime @default(now())

  item EvaluationItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([evaluationId])
  @@index([itemId])
  @@index([section])
  @@index([category])
  @@map("evaluation_attachments")
}

/// Histórico de reavaliações de itens / mudanças sensíveis.
model EvaluationHistory {
  id           String   @id @default(cuid())
  tenantId     String
  evaluationId String
  itemId       String?
  serviceId    String?
  userId       String?
  userName     String?
  userRole     String?
  action       String // CREATE_ITEM | REVALUATE | ADD_SERVICE | UPDATE_SERVICE | REMOVE_SERVICE | ADD_ATTACHMENT | REMOVE_ATTACHMENT | FINISH | REOPEN
  oldValue     Json?
  newValue     Json?
  notes        String?
  createdAt    DateTime @default(now())

  item EvaluationItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([evaluationId])
  @@index([itemId])
  @@index([action])
  @@map("evaluation_history")
}

// ═════════════════════════════════════════════════════════════════════════════
// CENTRAL DE AVISOS — Regras e dispositivos móveis
// ═════════════════════════════════════════════════════════════════════════════

/// Regras configuráveis de notificação/pendência (MASTER global ou por tenant)
model NotificationRule {
  id                     String    @id @default(cuid())
  scope                  String    @default("GLOBAL") // GLOBAL | TENANT
  tenantId               String? // null = global (MASTER)
  name                   String
  description            String?
  module                 String // DEALS | PENDENCIES | COMMISSIONS | STOCK | CRM | WHATSAPP
  conditionType          String // ex: DEAL_PENDING_RELEASE | COMMISSION_OVERDUE | STOCK_PENDENCY | etc.
  conditionConfig        Json? // parâmetros específicos da condição
  priority               String    @default("MEDIA") // BAIXA | MEDIA | ALTA | URGENTE
  severity               String    @default("MEDIA") // LOW | MEDIUM | HIGH | CRITICAL
  slaMinutes             Int? // SLA padrão para pendências geradas por esta regra
  channels               String[] // APP_WEB | APP_MOBILE | WHATSAPP | EMAIL | PUSH
  targetRoles            String[] // roles que recebem: GERENTE | ADM | GERENTE_GERAL | etc.
  escalationRoles        String[] // roles para escalonamento
  escalationAfterMinutes Int? // minutos antes de escalonar
  maxPerDay              Int       @default(10) // máximo de notificações por dia por usuário
  isActive               Boolean   @default(true)
  startsAt               DateTime?
  endsAt                 DateTime?
  createdByUserId        String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  creator User? @relation("NotificationRuleCreator", fields: [createdByUserId], references: [id])

  @@index([scope, isActive])
  @@index([tenantId])
  @@index([module])
  @@map("notification_rules")
}

/// Dispositivos móveis para push notifications futuras
model MobileDevice {
  id          String    @id @default(cuid())
  userId      String
  deviceToken String    @unique // FCM/APNs token
  platform    String // ANDROID | IOS | WEB
  deviceName  String? // ex: "iPhone 15 Pro"
  appVersion  String?
  isActive    Boolean   @default(true)
  lastSeenAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([deviceToken])
  @@map("mobile_devices")
}

// ═════════════════════════════════════════════════════════════════════════════
// POLÍTICA DE SEGURANÇA GLOBAL — gerenciada pelo MASTER
// ═════════════════════════════════════════════════════════════════════════════

/// Política de segurança global da plataforma (singleton por escopo)
model SecurityPolicy {
  id                    String   @id @default(cuid())
  scope                 String   @default("GLOBAL") // GLOBAL | TENANT
  scopeId               String? // tenantId se scope=TENANT
  // Senha
  minPasswordLength     Int      @default(8)
  requireUppercase      Boolean  @default(true)
  requireNumber         Boolean  @default(true)
  requireSpecialChar    Boolean  @default(false)
  passwordExpiryDays    Int      @default(0) // 0 = nunca expira
  // Sessão
  sessionMaxAgeSecs     Int      @default(28800) // 8h
  inactivityTimeoutSecs Int      @default(0) // 0 = sem timeout
  maxActiveSessions     Int      @default(5)
  // Bloqueio por tentativas
  maxLoginAttempts      Int      @default(5)
  lockoutDurationMins   Int      @default(15)
  // 2FA
  require2FA            Boolean  @default(false)
  require2FAForMaster   Boolean  @default(true)
  // IP allowlist (MASTER)
  masterIpAllowlist     String[] // IPs permitidos para MASTER (vazio = todos)
  // Dados
  dataRetentionDays     Int      @default(365)
  updatedById           String?
  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())

  @@unique([scope, scopeId])
  @@map("security_policies")
}

// =============================================================================
// CommunicationTestLog — Registro de testes de conexão/envio (E-mail e WhatsApp)
// Gravado a cada teste disparado pela Central de Comunicação do painel Master.
// =============================================================================

model CommunicationTestLog {
  id           String   @id @default(cuid())
  channel      String // EMAIL | WHATSAPP
  provider     String? // smtp | sendgrid | ses | mailgun | resend | meta | evolution | zapi | twilio
  triggeredBy  String // userId do master que disparou o teste
  target       String // e-mail ou telefone testado
  success      Boolean
  errorCode    String? // código do erro (ex: ECONNREFUSED, 535, 131047)
  errorMessage String? // mensagem descritiva do erro
  errorDetails String? // stack / response body completo para debug
  responseMs   Int? // latência em ms
  messageId    String? // ID externo da mensagem (sucesso)
  metadata     Json? // payload de resposta completo
  createdAt    DateTime @default(now())

  user User @relation("CommunicationTestLogs", fields: [triggeredBy], references: [id])

  @@index([channel, createdAt])
  @@index([triggeredBy])
  @@index([success])
  @@map("communication_test_logs")
}

// ═════════════════════════════════════════════════════════════════════════════
// METAS COMERCIAIS & RANKING
// Regra de negócio: toda meta tem um ESCOPO (USER/UNIT/TENANT/GLOBAL). Nunca
// misturar escopos numa mesma query — sempre filtrar por tenantId e, conforme
// o escopo, por unitId/userId. Cálculo centralizado no service layer.
// ═════════════════════════════════════════════════════════════════════════════

/// Tipo de meta comercial (cada um agrega de uma fonte diferente)
enum GoalType {
  SALES_EXCHANGE // vendas e trocas concluídas
  PURCHASE // compras concluídas
  RETURN // retornos concluídos
  DOCUMENTATION // despachante / documentação concluída
  EXTENDED_WARRANTY // garantia estendida vendida
  SERVICE // serviços vendidos/vinculados
}

/// Escopo da meta — define o nível de agregação e os filtros obrigatórios
enum GoalScope {
  USER // meta individual de um vendedor (filtra tenantId + userId)
  ROLE // meta por cargo/função (filtra tenantId + targetRole)
  UNIT // meta de uma unidade/filial (filtra tenantId + unitId)
  TENANT // meta da loja/empresa inteira (filtra tenantId)
  GLOBAL // meta da plataforma (apenas MASTER; tenantId nulo)
}

/// Período de apuração da meta
enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

/// Estado de uma meta
enum GoalStatus {
  ATIVA
  INATIVA
  ARQUIVADA
}

/// Definição de uma meta. O alvo base fica em `targetValue`; quando
/// `progressive = true`, os degraus ficam em GoalLevel (sem hardcode).
model Goal {
  id          String     @id @default(cuid())
  tenantId    String? // null = meta GLOBAL (plataforma)
  unitId      String? // preenchido quando scope = UNIT
  userId      String? // preenchido quando scope = USER
  targetRole  UserRole? // preenchido quando scope = ROLE
  type        GoalType
  scope       GoalScope
  period      GoalPeriod
  title       String?
  startDate   DateTime
  endDate     DateTime
  targetValue Decimal    @db.Decimal(14, 2) // alvo base (quantidade ou R$)
  measureUnit String     @default("QTD") // QTD | BRL | PERCENT
  progressive Boolean    @default(false) // usa degraus em GoalLevel
  active      Boolean    @default(true)
  status      GoalStatus @default(ATIVA)
  notes       String?
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant   Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit     Unit?          @relation("UnitGoals", fields: [unitId], references: [id])
  user     User?          @relation("UserGoals", fields: [userId], references: [id])
  levels   GoalLevel[]
  progress GoalProgress[]

  @@index([tenantId])
  @@index([unitId])
  @@index([userId])
  @@index([targetRole])
  @@index([type, scope, period])
  @@index([status])
  @@index([startDate, endDate])
  @@map("goals")
}

/// Degrau de progressão de uma meta (Meta 1, Meta 2, ...). Configurável pelo
/// administrador — sem valores fixos no código.
model GoalLevel {
  id          String   @id @default(cuid())
  goalId      String
  level       Int // 1, 2, 3, ...
  targetValue Decimal  @db.Decimal(14, 2)
  label       String? // ex: "Bronze", "Meta 1"
  reward      String? // descrição opcional de bônus/premiação
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, level])
  @@index([goalId])
  @@map("goal_levels")
}

/// Snapshot de progresso de uma meta num período. Mantido pelo service layer
/// (não calcular no front-end). Uma linha por meta por janela de período.
model GoalProgress {
  id            String    @id @default(cuid())
  goalId        String
  tenantId      String?
  unitId        String?
  userId        String?
  periodStart   DateTime
  periodEnd     DateTime
  achievedValue Decimal   @default(0) @db.Decimal(14, 2)
  percent       Decimal   @default(0) @db.Decimal(7, 2) // % atingido (0–100+)
  currentLevel  Int       @default(0) // maior nível alcançado
  reachedAt     DateTime? // quando bateu o alvo base
  computedAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, periodStart])
  @@index([goalId])
  @@index([tenantId])
  @@index([userId])
  @@index([unitId])
  @@map("goal_progress")
}

/// Pesos e critérios de desempate do ranking, configuráveis por tenant.
/// Defaults seguem a sugestão de pontuação da especificação.
model RankingRule {
  id                    String   @id @default(cuid())
  tenantId              String? // null = regra padrão da plataforma
  name                  String   @default("Padrão")
  active                Boolean  @default(true)
  // Pesos (pontos por evento concluído)
  weightSale            Int      @default(100) // venda/troca concluída
  weightPurchase        Int      @default(40) // compra concluída
  weightReturn          Int      @default(25) // retorno concluído
  weightDocumentation   Int      @default(20) // documento/despachante concluído
  weightWarranty        Int      @default(30) // garantia estendida vendida
  weightService         Int      @default(20) // serviço vendido
  weightOverduePendency Int      @default(-15) // pendência vencida
  weightCanceledSale    Int      @default(-50) // venda cancelada
  weightLateDocument    Int      @default(-10) // documento atrasado
  // Ordem de critérios de desempate (lista de chaves). Default no service layer.
  tiebreakers           Json?
  notes                 String?
  createdBy             String?
  updatedBy             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scores RankingScore[]

  @@index([tenantId])
  @@map("ranking_rules")
}

/// Pontuação calculada de um vendedor num período (cache do ranking).
/// Recalculada pelo service layer; o front consome pronto.
model RankingScore {
  id                String     @id @default(cuid())
  ruleId            String?
  tenantId          String?
  unitId            String?
  userId            String // vendedor pontuado
  period            GoalPeriod
  periodStart       DateTime
  periodEnd         DateTime
  // Métricas agregadas (snapshot da janela)
  sales             Int        @default(0)
  purchases         Int        @default(0)
  returns           Int        @default(0)
  documentations    Int        @default(0)
  warranties        Int        @default(0)
  services          Int        @default(0)
  overduePendencies Int        @default(0)
  canceledSales     Int        @default(0)
  lateDocuments     Int        @default(0)
  // Resultado
  totalPoints       Int        @default(0)
  qualityScore      Decimal    @default(0) @db.Decimal(7, 2) // índice de qualidade da venda
  rankGeneral       Int? // posição no ranking geral do tenant
  rankUnit          Int? // posição no ranking da unidade
  computedAt        DateTime   @default(now())
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  rule   RankingRule? @relation(fields: [ruleId], references: [id])
  tenant Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit   Unit?        @relation("UnitRankingScores", fields: [unitId], references: [id])
  user   User         @relation("UserRankingScores", fields: [userId], references: [id])

  @@unique([tenantId, userId, periodStart, periodEnd])
  @@index([tenantId])
  @@index([unitId])
  @@index([userId])
  @@index([periodStart, periodEnd])
  @@map("ranking_scores")
}

// ═════════════════════════════════════════════════════════════════════════════
// FINANCEIRO (lançamentos manuais + integração com vendas/comissões)
// Aditivo: tabelas novas, sem FK para models existentes (dealId/sellerId/unitId
// guardados como String e resolvidos na aplicação, como em AuditLog/Pendency).
// ═════════════════════════════════════════════════════════════════════════════

enum FinancialEntryType {
  RECEITA
  DESPESA
}

enum FinancialEntryStatus {
  PREVISTO // a pagar / a receber (ainda não liquidado)
  PAGO // despesa quitada
  RECEBIDO // receita recebida
  CANCELADO
}

enum FinancialAccountType {
  CAIXA
  BANCO
  CARTAO
  OUTRO
}

model FinancialAccount {
  id             String               @id @default(cuid())
  tenantId       String?
  name           String
  type           FinancialAccountType @default(CAIXA)
  openingBalance Decimal              @default(0) @db.Decimal(14, 2)
  active         Boolean              @default(true)
  createdById    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  entries FinancialEntry[]

  @@index([tenantId])
  @@map("financial_accounts")
}

model FinancialCategory {
  id        String             @id @default(cuid())
  tenantId  String?
  name      String
  kind      FinancialEntryType // RECEITA ou DESPESA
  color     String?
  active    Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  entries FinancialEntry[]

  @@index([tenantId])
  @@index([kind])
  @@map("financial_categories")
}

model FinancialEntry {
  id                      String               @id @default(cuid())
  tenantId                String?
  unitId                  String?
  accountId               String?
  categoryId              String?
  type                    FinancialEntryType
  status                  FinancialEntryStatus @default(PREVISTO)
  description             String
  amount                  Decimal              @db.Decimal(14, 2)
  dueDate                 DateTime?
  paidDate                DateTime?
  competenceDate          DateTime? // data de competência (DRE)
  // Integração com vendas/comissões (idempotência por origem)
  dealId                  String?
  commissionCalculationId String?
  sellerId                String?
  source                  String?              @default("MANUAL") // MANUAL | VENDA | COMISSAO | RETORNO | GARANTIA
  // Auxiliares
  counterparty            String? // fornecedor / cliente
  documentNumber          String?
  paymentMethod           String?
  notes                   String?
  createdById             String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  account  FinancialAccount?  @relation(fields: [accountId], references: [id])
  category FinancialCategory? @relation(fields: [categoryId], references: [id])

  @@unique([commissionCalculationId])
  @@unique([dealId, source])
  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([dueDate])
  @@index([paidDate])
  @@index([competenceDate])
  @@index([sellerId])
  @@index([unitId])
  @@map("financial_entries")
}

// ═════════════════════════════════════════════════════════════════════════════
// FINANCIAMENTO (FN) — proponentes, bancos, fichas/simulações
// Aditivo: tabelas novas; sellerId/createdById guardados como String (resolvidos
// na app). FK apenas entre as tabelas novas (proposal → proponent/bank).
// ═════════════════════════════════════════════════════════════════════════════

enum ProponentOccupation {
  AUTONOMO
  CLT
  EMPRESARIO
  APOSENTADO_PENSIONISTA
}

enum FinanceProposalStatus {
  SIMULACAO // simulação (ainda não enviada ao banco)
  ENVIADA // ficha passada/enviada ao banco
  APROVADA
  RECUSADA
  CANCELADA
}

model FinanceProponent {
  id                 String               @id @default(cuid())
  tenantId           String?
  // ── Dados pessoais (obrigatórios, exceto telefoneFixo) ──────────────────
  nomeCompleto       String
  dataNascimento     DateTime?
  cpf                String?
  rg                 String?
  nomeMae            String?
  nomePai            String?
  email              String?
  celular            String?
  telefoneFixo       String?
  // ── Endereço residencial ────────────────────────────────────────────────
  cep                String?
  logradouro         String?
  bairro             String?
  cidade             String?
  estado             String?
  numero             String?
  complemento        String?
  // ── Ocupação / renda ─────────────────────────────────────────────────────
  occupation         ProponentOccupation?
  cargo              String? // autônomo: cargo
  renda              Decimal?             @db.Decimal(14, 2)
  outrasRendas       Json? // [{ descricao, valor }]
  numeroBeneficio    String? // aposentado/pensionista
  // ── Dados da empresa (CLT/empresário/autônomo opcional) ──────────────────
  empresaNome        String?
  empresaCnpj        String?
  empresaTelefone    String?
  empresaCep         String?
  empresaLogradouro  String?
  empresaBairro      String?
  empresaCidade      String?
  empresaEstado      String?
  empresaNumero      String?
  empresaComplemento String?
  // ── Meta ─────────────────────────────────────────────────────────────────
  notes              String?
  createdById        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  proposals   FinanceProposal[]
  simulations FinanceSimulation[]
  consents    FinanceConsent[]
  documents   FinanceProposalDocument[]

  @@index([tenantId])
  @@index([cpf])
  @@index([nomeCompleto])
  @@map("finance_proponents")
}

model FinanceBank {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  code      String? // código/identificador do banco
  active    Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proposals FinanceProposal[]

  @@index([tenantId])
  @@map("finance_banks")
}

model FinanceProposal {
  id               String                @id @default(cuid())
  tenantId         String?
  proponentId      String
  bankId           String?
  sellerId         String?
  dealId           String? // ligação opcional com a negociação (F&I)
  // ── Dados da operação ────────────────────────────────────────────────────
  vehicle          String?
  amountRequested  Decimal?              @db.Decimal(14, 2)
  downPayment      Decimal?              @db.Decimal(14, 2)
  installments     Int?
  status           FinanceProposalStatus @default(SIMULACAO)
  // ── Resultado / simulação ────────────────────────────────────────────────
  simulationResult Json?
  approvedValue    Decimal?              @db.Decimal(14, 2)
  monthlyPayment   Decimal?              @db.Decimal(14, 2)
  rejectionReason  String?
  notes            String?
  createdById      String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  proponent    FinanceProponent            @relation(fields: [proponentId], references: [id], onDelete: Cascade)
  bank         FinanceBank?                @relation(fields: [bankId], references: [id])
  deal         Deal?                       @relation("DealFinanceProposals", fields: [dealId], references: [id], onDelete: SetNull)
  submissions  FinanceProposalSubmission[]
  events       FinanceProposalEvent[]
  documents    FinanceProposalDocument[]
  productSales FinanceProductSale[]

  @@index([tenantId])
  @@index([status])
  @@index([proponentId])
  @@index([bankId])
  @@index([sellerId])
  @@index([dealId])
  @@map("finance_proposals")
}

// ═════════════════════════════════════════════════════════════════════════════
// F&I FASE 4 — provedores, integrações, credenciais, regras, simulação, fichas
// Aditivo. Credenciais nunca em texto puro (secretsEncrypted). Logs sem segredo.
// ═════════════════════════════════════════════════════════════════════════════

enum FinanceProviderKind {
  CREDERE
  BANCO_DIRETO
  INTEGRADOR
  MANUAL
  OUTRO
}

enum FinanceEnvironment {
  HOMOLOGACAO
  PRODUCAO
}

model FinanceProvider {
  id               String                     @id @default(cuid())
  name             String
  kind             FinanceProviderKind        @default(MANUAL)
  active           Boolean                    @default(true)
  baseUrlHomolog   String?
  baseUrlProd      String?
  apiVersion       String?
  supportsSimulate Boolean                    @default(false)
  supportsSubmit   Boolean                    @default(false)
  supportsWebhook  Boolean                    @default(false)
  supportsStatus   Boolean                    @default(false)
  fieldMappings    Json? // de/para campos AutoDrive → API do provedor (Master)
  notes            String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  providerBanks    FinanceProviderBank[]
  integrations     FinanceTenantIntegration[]

  @@map("finance_providers")
}

model FinanceProviderBank {
  id         String          @id @default(cuid())
  providerId String
  name       String
  code       String?
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  provider   FinanceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("finance_provider_banks")
}

model FinanceTenantIntegration {
  id             String              @id @default(cuid())
  tenantId       String
  providerId     String
  environment    FinanceEnvironment  @default(HOMOLOGACAO)
  active         Boolean             @default(true)
  storeCode      String?
  webhookActive  Boolean             @default(false)
  lastTestAt     DateTime?
  lastTestStatus String?
  createdById    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  provider       FinanceProvider     @relation(fields: [providerId], references: [id])
  credentials    FinanceCredential[]

  @@index([tenantId])
  @@index([providerId])
  @@map("finance_tenant_integrations")
}

model FinanceCredential {
  id               String                    @id @default(cuid())
  tenantId         String
  integrationId    String?
  bankId           String?
  label            String?
  environment      FinanceEnvironment        @default(HOMOLOGACAO)
  secretsEncrypted String? // ciphertext do JSON {usuario,senha,token,clientId,clientSecret}
  maskedHints      Json? // ex.: { token: "****8F2A" } para exibição
  createdById      String?
  updatedById      String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  integration      FinanceTenantIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([bankId])
  @@map("finance_credentials")
}

model FinanceBankPriority {
  id        String   @id @default(cuid())
  tenantId  String
  bankId    String
  priority  Int      @default(1)
  active    Boolean  @default(true)
  rule      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, bankId])
  @@index([tenantId])
  @@map("finance_bank_priorities")
}

model FinanceRoutingRule {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  condition Json
  bankId    String?
  priority  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("finance_routing_rules")
}

model FinanceReturnRule {
  id              String   @id @default(cuid())
  tenantId        String
  bankId          String?
  percent         Decimal? @db.Decimal(6, 2)
  fixedValue      Decimal? @db.Decimal(14, 2)
  minInstallments Int?
  maxInstallments Int?
  notes           String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([bankId])
  @@map("finance_return_rules")
}

model FinanceProduct {
  id           String               @id @default(cuid())
  tenantId     String
  name         String
  kind         String? // SEGURO | GARANTIA | PROTECAO | RASTREADOR | OUTRO
  defaultValue Decimal?             @db.Decimal(14, 2)
  active       Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  sales        FinanceProductSale[]

  @@index([tenantId])
  @@map("finance_products")
}

model FinanceProductSale {
  id          String           @id @default(cuid())
  tenantId    String
  productId   String?
  proposalId  String?
  description String
  value       Decimal          @db.Decimal(14, 2)
  createdAt   DateTime         @default(now())
  product     FinanceProduct?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  proposal    FinanceProposal? @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([proposalId])
  @@map("finance_product_sales")
}

model FinanceConsent {
  id          String           @id @default(cuid())
  tenantId    String
  proponentId String
  type        String // TRATAMENTO_DADOS | ENVIO_BANCO
  granted     Boolean          @default(false)
  grantedAt   DateTime?
  ip          String?
  notes       String?
  createdAt   DateTime         @default(now())
  proponent   FinanceProponent @relation(fields: [proponentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([proponentId])
  @@map("finance_consents")
}

model FinanceSimulation {
  id             String                    @id @default(cuid())
  tenantId       String
  proponentId    String?
  vehicle        String?
  vehicleValue   Decimal?                  @db.Decimal(14, 2)
  downPayment    Decimal?                  @db.Decimal(14, 2)
  financedAmount Decimal?                  @db.Decimal(14, 2)
  installments   Int?
  sellerId       String?
  notes          String?
  createdById    String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  proponent      FinanceProponent?         @relation(fields: [proponentId], references: [id], onDelete: SetNull)
  options        FinanceSimulationOption[]

  @@index([tenantId])
  @@index([proponentId])
  @@map("finance_simulations")
}

model FinanceSimulationOption {
  id               String            @id @default(cuid())
  simulationId     String
  bankId           String?
  installments     Int?
  installmentValue Decimal?          @db.Decimal(14, 2)
  rate             Decimal?          @db.Decimal(8, 4)
  cet              Decimal?          @db.Decimal(8, 4)
  estimatedReturn  Decimal?          @db.Decimal(14, 2)
  status           String?
  createdAt        DateTime          @default(now())
  simulation       FinanceSimulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@index([simulationId])
  @@map("finance_simulation_options")
}

model FinanceProposalSubmission {
  id              String                 @id @default(cuid())
  tenantId        String
  proposalId      String
  bankId          String?
  providerId      String?
  environment     FinanceEnvironment     @default(HOMOLOGACAO)
  externalId      String?
  status          String                 @default("ENVIADA")
  requestPayload  Json?
  responsePayload Json?
  submittedById   String?
  submittedAt     DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  proposal        FinanceProposal        @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  events          FinanceProposalEvent[]

  @@index([tenantId])
  @@index([proposalId])
  @@index([externalId])
  @@map("finance_proposal_submissions")
}

model FinanceProposalEvent {
  id           String                     @id @default(cuid())
  tenantId     String?
  proposalId   String?
  submissionId String?
  type         String // STATUS_CHANGE | WEBHOOK | NOTE
  status       String?
  message      String?
  source       String? // MANUAL | WEBHOOK | API
  createdById  String?
  createdAt    DateTime                   @default(now())
  proposal     FinanceProposal?           @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  submission   FinanceProposalSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  @@index([proposalId])
  @@index([submissionId])
  @@map("finance_proposal_events")
}

model FinanceProposalDocument {
  id          String            @id @default(cuid())
  tenantId    String
  proposalId  String?
  proponentId String?
  type        String // CNH | COMPROVANTE | HOLERITE | ...
  fileUrl     String?
  fileName    String?
  required    Boolean           @default(false)
  status      String            @default("PENDENTE") // PENDENTE | APROVADO | REPROVADO
  notes       String?
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  proposal    FinanceProposal?  @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  proponent   FinanceProponent? @relation(fields: [proponentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([proposalId])
  @@index([proponentId])
  @@map("finance_proposal_documents")
}

model FinanceWebhookEvent {
  id             String   @id @default(cuid())
  tenantId       String?
  provider       String?
  externalId     String?
  signatureValid Boolean?
  payload        Json
  processed      Boolean  @default(false)
  error          String?
  createdAt      DateTime @default(now())

  @@index([processed])
  @@index([externalId])
  @@map("finance_webhook_events")
}

model FinanceIntegrationLog {
  id         String   @id @default(cuid())
  tenantId   String?
  providerId String?
  action     String // TEST_CONNECTION | SIMULATE | SUBMIT | STATUS | WEBHOOK
  status     String? // OK | ERROR
  durationMs Int?
  message    String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([providerId])
  @@index([createdAt])
  @@map("finance_integration_logs")
}

// Configurações genéricas do F&I por loja (chave/JSON). Ex.: documentos
// obrigatórios por perfil, permissões operacionais do F&I. Tenant-scoped.
model FinanceTenantSetting {
  id          String   @id @default(cuid())
  tenantId    String
  key         String // ex.: 'required_documents' | 'permissions'
  value       Json // conteúdo da configuração
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("finance_tenant_settings")
}

// =============================================================================
// MÓDULO DE IA CONTROLADA (aditivo) — pipeline de documentos + IA do AutoDrive.
// Tudo opcional/global por padrão; tenant-scoped onde aplicável. Sem segredo em
// texto puro (AiProvider.secretsEncrypted). Ver README_ROBOTS.md (LOG 0063+).
// =============================================================================

enum DocumentProcessingStatus {
  uploaded
  processing
  text_extracted
  requires_ocr
  ai_processed
  failed
  unsupported
  corrupted
  protected
  too_large
}

enum AiProviderKind {
  GEMINI
  OPENAI
  ANTHROPIC
  CUSTOM
}

enum AiEnvironment {
  SANDBOX
  PRODUCAO
}

// Job de processamento de um documento (extração de texto / IA).
model DocumentProcessingJob {
  id              String                   @id @default(cuid())
  tenantId        String?
  documentId      String? // referência opcional ao documento de origem
  sourceModule    String? // ex.: financing, evaluation, contracts
  fileName        String?
  mimeType        String?
  fileSize        Int?
  status          DocumentProcessingStatus @default(uploaded)
  extractedText   String?
  aiSummary       String?
  errorMessage    String?
  providerUsed    String?
  createdByUserId String?
  processedAt     DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([tenantId])
  @@index([documentId])
  @@index([status])
  @@map("document_processing_jobs")
}

// Provedor de IA — GLOBAL (configurado pelo MASTER). Segredos cifrados.
model AiProvider {
  id                  String         @id @default(cuid())
  name                String
  code                String         @unique // identificador interno (ex.: gemini-default)
  kind                AiProviderKind @default(CUSTOM)
  priority            Int            @default(100) // ordem de failover (1 = tentado primeiro)
  model               String? // modelo padrão
  authType            String? // API_KEY | OAUTH | CUSTOM
  secretsEncrypted    String? // ciphertext {apiKey, clientSecret, ...} — nunca texto puro
  maskedHints         Json? // exibição mascarada
  baseUrl             String?
  active              Boolean        @default(false)
  environment         AiEnvironment  @default(SANDBOX)
  maxTokensPerRequest Int?
  dailyLimit          Int?
  monthlyLimit        Int?
  timeoutMs           Int?
  allowPdf            Boolean        @default(false)
  allowImage          Boolean        @default(false)
  allowReports        Boolean        @default(false)
  allowHelpChat       Boolean        @default(false)
  allowDocAnalysis    Boolean        @default(false)
  notes               String?
  createdById         String?
  updatedById         String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@map("ai_providers")
}

// Instrução de comportamento da IA (ensinar a IA). Global se tenantId null.
model AiInstruction {
  id          String                 @id @default(cuid())
  tenantId    String?
  title       String
  area        String?
  scope       String                 @default("global") // global|ajuda|relatorios|documentos|f&i|estoque|vendas|financeiro|pos-venda|marketing
  content     String
  status      String                 @default("ATIVO") // ATIVO|INATIVO
  priority    Int                    @default(0)
  createdById String?
  updatedById String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  versions    AiInstructionVersion[]

  @@index([tenantId])
  @@index([scope])
  @@map("ai_instructions")
}

model AiInstructionVersion {
  id            String        @id @default(cuid())
  instructionId String
  version       Int
  content       String
  scope         String?
  createdById   String?
  createdAt     DateTime      @default(now())
  instruction   AiInstruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)

  @@index([instructionId])
  @@map("ai_instruction_versions")
}

// Base de conhecimento da IA. Global (Master) ou do tenant.
model AiKnowledgeBase {
  id               String             @id @default(cuid())
  tenantId         String?
  scope            String             @default("global") // global|tenant
  title            String
  description      String?
  content          String?
  sourceType       String             @default("manual_text") // manual_text|pdf|docx|image|url|system_doc
  sourceDocumentId String?
  status           String             @default("ATIVO") // ATIVO|INATIVO
  createdByUserId  String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  chunks           AiKnowledgeChunk[]

  @@index([tenantId])
  @@index([scope])
  @@map("ai_knowledge_base")
}

model AiKnowledgeChunk {
  id              String          @id @default(cuid())
  knowledgeBaseId String
  tenantId        String?
  chunkText       String
  chunkIndex      Int             @default(0)
  metadata        Json?
  embedding       Json? // placeholder (sem pgvector nesta fase)
  createdAt       DateTime        @default(now())
  knowledgeBase   AiKnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
  @@index([tenantId])
  @@map("ai_knowledge_chunks")
}

// Log de uso da IA (sem dados sensíveis / sem prompt completo).
model AiUsageLog {
  id            String   @id @default(cuid())
  tenantId      String?
  userId        String?
  providerId    String?
  feature       String // help_chat | analyze_document | summarize_report | ...
  promptSummary String? // resumo/hash — nunca o conteúdo sensível completo
  tokenInput    Int?
  tokenOutput   Int?
  costEstimate  Decimal? @db.Decimal(12, 6)
  status        String   @default("OK") // OK | ERROR | BLOCKED
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([providerId])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

// =============================================================================
// MARKETING — Mesa SDR / Pré-Vendas + Telefonia (Fase 2: schema aditivo).
// Apenas estrutura/tomadas. Distribuição inteligente, lock transacional do
// tanque de tubarão e integração real de telefonia ficam para fases futuras.
// Convenções: tenantId/userId/unitId são FKs soltos (igual a F&I/IA — sem
// back-relation em Tenant/User). Credenciais SEMPRE cifradas (secretsEncrypted)
// + maskedHints; nunca texto puro. MASTER nunca vê credencial do tenant (BYOC).
// =============================================================================

enum LeadDistributionMode {
  ROUND_ROBIN // roleta — próximo disponível
  SHARK_TANK // tanque de tubarão — primeiro que assumir
  MANUAL // livre — atribuição manual
  LOAD_BALANCED // menor carga de leads abertos
  PERFORMANCE_WEIGHTED // peso por performance (futuro)
  PRIORITY_RULES // regras por origem/unidade/veículo
}

enum LeadStatus {
  NEW // recém-criado, não distribuído
  ASSIGNED // atribuído a um responsável
  WORKING // em atendimento
  QUALIFIED // qualificado (apto p/ vendedor)
  CONVERTED // convertido (virou negociação/venda)
  LOST // perdido
  DISCARDED // descartado/inválido
  RECYCLED // reciclado p/ nova distribuição
}

enum AgentPresenceStatus {
  ONLINE
  BUSY
  AWAY
  OFFLINE
  ON_CALL
}

enum CallDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum CallStatus {
  RINGING
  ANSWERED
  MISSED
  BUSY
  FAILED
  COMPLETED
  VOICEMAIL
  CANCELED
}

enum RecordingStatus {
  PENDING // ainda não disponível
  AVAILABLE // disponível p/ acesso controlado
  FAILED
  EXPIRED // expirou pela política de retenção
  BLOCKED // bloqueado (LGPD / política do tenant)
  DELETED
}

// Tipos de provedor de telefonia homologados pela plataforma (Master).
enum TelephonyProviderKind {
  ASTERISK
  THREE_CX
  TWILIO
  GENERIC_WEBHOOK
  MANUAL
}

// ── SDR / Pré-Vendas ─────────────────────────────────────────────────────────

// Entidade-âncora do módulo: o lead que a mesa trata. (Adicionada além da lista
// sugerida — todos os models de SDR/telefonia referenciam o lead.)
model MarketingLead {
  id               String                    @id @default(cuid())
  tenantId         String
  status           LeadStatus                @default(NEW)
  source           String? // origem (site, whatsapp, ligação, indicação, etc.)
  unitId           String?
  teamId           String?
  name             String?
  phone            String?
  email            String?
  customerId       String? // cliente vinculado (Customer)
  vehicleId        String? // veículo de interesse
  assignedToUserId String? // responsável atual
  // Lock otimista do tanque de tubarão (Fase 3): assume com UPDATE ... WHERE claimedByUserId IS NULL.
  claimedByUserId  String?
  claimedAt        DateTime?
  score            Int?
  lastContactAt    DateTime?
  convertedDealId  String? // negociação resultante
  convertedAt      DateTime?
  lostReason       String?
  notes            String?
  metadata         Json?
  createdById      String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  assignments      MarketingLeadAssignment[]
  claims           MarketingLeadClaim[]
  tasks            MarketingLeadTask[]
  slas             MarketingLeadSla[]
  calls            TelephonyCall[]

  @@index([tenantId])
  @@index([status])
  @@index([assignedToUserId])
  @@index([unitId])
  @@map("marketing_leads")
}

model MarketingSdrTeam {
  id          String               @id @default(cuid())
  tenantId    String
  name        String
  description String?
  unitId      String?
  active      Boolean              @default(true)
  createdById String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  members     MarketingSdrMember[]

  @@index([tenantId])
  @@map("marketing_sdr_teams")
}

model MarketingSdrMember {
  id             String              @id @default(cuid())
  tenantId       String
  teamId         String
  userId         String
  role           String              @default("SDR") // SDR | LEADER
  active         Boolean             @default(true)
  presence       AgentPresenceStatus @default(OFFLINE)
  maxOpenLeads   Int?
  weight         Decimal?            @db.Decimal(6, 2) // peso p/ PERFORMANCE_WEIGHTED (futuro)
  unitId         String?
  lastAssignedAt DateTime?
  lastPresenceAt DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  team           MarketingSdrTeam    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("marketing_sdr_members")
}

model MarketingLeadDistributionPolicy {
  id          String               @id @default(cuid())
  tenantId    String
  name        String
  mode        LeadDistributionMode @default(ROUND_ROBIN)
  active      Boolean              @default(true)
  teamId      String?
  unitId      String?
  priority    Int                  @default(0)
  // Parâmetros: slaSeconds, fallbackMode, maxOpenLeads, allowedSources, weights, horários...
  config      Json?
  createdById String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([tenantId])
  @@index([teamId])
  @@map("marketing_lead_distribution_policies")
}

model MarketingLeadDistributionQueue {
  id                String               @id @default(cuid())
  tenantId          String
  policyId          String?
  leadId            String?
  mode              LeadDistributionMode @default(ROUND_ROBIN)
  status            String               @default("PENDING") // PENDING | DISTRIBUTED | FALLBACK | CANCELED
  unitId            String?
  source            String?
  position          Int?
  enqueuedAt        DateTime             @default(now())
  processedAt       DateTime?
  fallbackAppliedAt DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([tenantId])
  @@index([policyId])
  @@index([status])
  @@map("marketing_lead_distribution_queue")
}

// Histórico/auditoria de toda atribuição, aceite, recusa, redistribuição e conversão.
model MarketingLeadAssignment {
  id               String               @id @default(cuid())
  tenantId         String
  leadId           String
  assignedToUserId String?
  assignedByUserId String?
  teamId           String?
  mode             LeadDistributionMode @default(MANUAL)
  // ASSIGNED | ACCEPTED | REFUSED | REDISTRIBUTED | EXPIRED | CONVERTED
  status           String               @default("ASSIGNED")
  reason           String?
  slaDeadline      DateTime?
  respondedAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  lead             MarketingLead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([leadId])
  @@index([assignedToUserId])
  @@index([status])
  @@map("marketing_lead_assignments")
}

// Tanque de tubarão: registra quem visualizou, tentou assumir e quem assumiu.
model MarketingLeadClaim {
  id        String        @id @default(cuid())
  tenantId  String
  leadId    String
  userId    String
  action    String        @default("VIEWED") // VIEWED | ATTEMPTED | CLAIMED | LOST_RACE
  succeeded Boolean       @default(false)
  createdAt DateTime      @default(now())
  lead      MarketingLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([leadId])
  @@index([userId])
  @@map("marketing_lead_claims")
}

// SLA de atendimento do lead (redistribuir / avisar gerente se estourar).
model MarketingLeadSla {
  id                String        @id @default(cuid())
  tenantId          String
  leadId            String
  assignmentId      String?
  slaSeconds        Int
  startedAt         DateTime      @default(now())
  deadline          DateTime
  status            String        @default("PENDING") // PENDING | MET | BREACHED | ESCALATED
  breachedAt        DateTime?
  escalatedToUserId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  lead              MarketingLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([leadId])
  @@index([status])
  @@map("marketing_lead_slas")
}

// Cadência/sequência de follow-up (definição). Passos em JSON nesta fase.
model MarketingLeadCadence {
  id          String              @id @default(cuid())
  tenantId    String
  name        String
  description String?
  active      Boolean             @default(true)
  steps       Json?
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  tasks       MarketingLeadTask[]

  @@index([tenantId])
  @@map("marketing_lead_cadences")
}

model MarketingLeadTask {
  id               String                @id @default(cuid())
  tenantId         String
  leadId           String?
  assignmentId     String?
  cadenceId        String?
  assignedToUserId String?
  type             String                @default("FOLLOW_UP") // CALL | EMAIL | WHATSAPP | FOLLOW_UP | OTHER
  title            String
  status           String                @default("PENDING") // PENDING | DONE | SKIPPED | CANCELED
  dueAt            DateTime?
  completedAt      DateTime?
  notes            String?
  createdById      String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  lead             MarketingLead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  cadence          MarketingLeadCadence? @relation(fields: [cadenceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([leadId])
  @@index([assignedToUserId])
  @@index([status])
  @@map("marketing_lead_tasks")
}

// ── Telefonia ────────────────────────────────────────────────────────────────

// Provedor homologado pela plataforma (camada técnica GLOBAL — Master). Sem tenantId.
model TelephonyProvider {
  id                String                      @id @default(cuid())
  name              String
  kind              TelephonyProviderKind       @default(MANUAL)
  active            Boolean                     @default(true)
  supportsInbound   Boolean                     @default(false)
  supportsOutbound  Boolean                     @default(false)
  supportsRecording Boolean                     @default(false)
  supportsWebhook   Boolean                     @default(false)
  baseUrl           String?
  apiVersion        String?
  fieldMappings     Json? // de/para AutoDrive → API do provedor (Master)
  notes             String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  connections       TelephonyTenantConnection[]

  @@map("telephony_providers")
}

// Conexão do tenant com um provedor (BYOC — credenciais da loja).
model TelephonyTenantConnection {
  id             String                @id @default(cuid())
  tenantId       String
  providerId     String
  environment    String                @default("PRODUCAO") // HOMOLOGACAO | PRODUCAO
  active         Boolean               @default(true)
  label          String?
  webhookActive  Boolean               @default(false)
  lastTestAt     DateTime?
  lastTestStatus String?
  createdById    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  provider       TelephonyProvider     @relation(fields: [providerId], references: [id])
  credentials    TelephonyCredential[]
  numbers        TelephonyNumber[]

  @@index([tenantId])
  @@index([providerId])
  @@map("telephony_tenant_connections")
}

// Credenciais cifradas, tenant-scoped (MASTER nunca vê).
model TelephonyCredential {
  id               String                     @id @default(cuid())
  tenantId         String
  connectionId     String?
  label            String?
  secretsEncrypted String? // ciphertext {sipUser, sipPassword, apiKey, token, accountSid, ...}
  maskedHints      Json? // ex.: { token: "****8F2A" }
  createdById      String?
  updatedById      String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  connection       TelephonyTenantConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([connectionId])
  @@map("telephony_credentials")
}

// Número rastreável / ramal por unidade/origem.
model TelephonyNumber {
  id           String                     @id @default(cuid())
  tenantId     String
  connectionId String?
  number       String // E.164
  label        String?
  extension    String?
  unitId       String?
  source       String? // origem rastreável (campanha/canal)
  inbound      Boolean                    @default(true)
  outbound     Boolean                    @default(true)
  active       Boolean                    @default(true)
  createdById  String?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  connection   TelephonyTenantConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  calls        TelephonyCall[]

  @@index([tenantId])
  @@index([connectionId])
  @@index([number])
  @@map("telephony_numbers")
}

model TelephonyRoutingRule {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  condition    Json
  numberId     String?
  targetUserId String?
  targetTeamId String?
  priority     Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@map("telephony_routing_rules")
}

model TelephonyCall {
  id             String               @id @default(cuid())
  tenantId       String
  connectionId   String?
  providerCallId String? // id externo no provedor
  direction      CallDirection        @default(INBOUND)
  status         CallStatus           @default(RINGING)
  fromNumber     String?
  toNumber       String?
  agentExtension String?
  agentUserId    String?
  numberId       String?
  leadId         String?
  customerId     String?
  source         String?
  startedAt      DateTime?
  answeredAt     DateTime?
  endedAt        DateTime?
  durationSec    Int?
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  number         TelephonyNumber?     @relation(fields: [numberId], references: [id], onDelete: SetNull)
  lead           MarketingLead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  events         TelephonyCallEvent[]
  recording      TelephonyRecording?

  @@index([tenantId])
  @@index([leadId])
  @@index([numberId])
  @@index([status])
  @@index([createdAt])
  @@map("telephony_calls")
}

model TelephonyCallEvent {
  id         String        @id @default(cuid())
  tenantId   String?
  callId     String
  type       String // ringing | answered | hangup | transfer | recording_ready | ...
  payload    Json?
  occurredAt DateTime      @default(now())
  createdAt  DateTime      @default(now())
  call       TelephonyCall @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId])
  @@map("telephony_call_events")
}

// Gravação de chamada — acesso controlado (URL protegida, retenção, LGPD).
model TelephonyRecording {
  id              String          @id @default(cuid())
  tenantId        String
  callId          String          @unique
  status          RecordingStatus @default(PENDING)
  storageUrl      String? // URL protegida (nunca pública)
  fileName        String?
  mimeType        String?
  durationSec     Int?
  sizeBytes       Int?
  retentionUntil  DateTime?
  deletedAt       DateTime?
  deletedByUserId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  call            TelephonyCall   @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@map("telephony_recordings")
}

// Evento bruto de webhook (para os endpoints futuros /api/webhooks/telephony/*).
model TelephonyWebhookEvent {
  id             String    @id @default(cuid())
  tenantId       String?
  providerKind   String?
  connectionId   String?
  eventType      String?
  externalId     String?
  payload        Json
  signatureValid Boolean?
  processed      Boolean   @default(false)
  processedAt    DateTime?
  callId         String?
  errorMessage   String?
  createdAt      DateTime  @default(now())

  @@index([tenantId])
  @@index([processed])
  @@index([createdAt])
  @@map("telephony_webhook_events")
}

// Log técnico de integração (teste/sync/chamada/webhook). Sem dados sensíveis.
model TelephonyIntegrationLog {
  id              String   @id @default(cuid())
  tenantId        String?
  connectionId    String?
  providerKind    String?
  action          String // TEST | SYNC | CALL | WEBHOOK | RECORDING_ACCESS | ...
  status          String   @default("OK") // OK | ERROR | BLOCKED
  message         String?
  metadata        Json?
  createdByUserId String?
  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([connectionId])
  @@index([createdAt])
  @@map("telephony_integration_logs")
}

// =============================================================================
// COMERCIAL — Fila de Atendimento ("Vendedor da Vez") — Fase 2 (schema aditivo).
// Atendimento presencial sem recepção: o sistema chama o vendedor da vez. A
// presença é validada por EVENTOS (nunca rastreio contínuo). Tudo tenant/unit.
// FKs soltos (tenantId/unitId/sellerId/actorId); relações só intra-módulo
// (queue → entries/attendances/arrivals/events). Não toca em Unit/User.
// =============================================================================

enum SellerQueueEntryStatus {
  WAITING
  NEXT
  CALLED
  ACCEPTED
  IN_ATTENDANCE
  PAUSED
  SKIPPED
  LEFT
  EXPIRED
  BLOCKED
}

enum SellerQueueEventType {
  CHECK_IN
  CHECK_OUT
  PAUSE
  RESUME
  CUSTOMER_ARRIVED
  CALLED
  ACCEPTED
  REJECTED
  TIMEOUT
  SKIPPED
  ATTENDANCE_STARTED
  ATTENDANCE_FINISHED
  MOVED_TO_END
  MANAGER_OVERRIDE
  LEADER_OVERRIDE
  QUEUE_REORDERED
  FRAUD_FLAGGED
}

enum SellerPresenceMethod {
  GPS
  QR_CODE
  DEVICE_CHECK
  MANAGER_OVERRIDE
  LEADER_OVERRIDE
  MANUAL_REVIEW
}

enum SellerAttendanceType {
  SALE
  EXCHANGE
  PURCHASE
  CONSIGNMENT
  FINANCING
  AFTER_SALES
  OTHER
}

enum SellerAttendanceResult {
  CONVERTED_TO_NEGOTIATION
  SCHEDULED_RETURN
  NO_INTEREST
  LOST
  DUPLICATED
  FORWARDED_TO_RESPONSIBLE
  INVALID_ATTENDANCE
}

// ── Fila INDIVIDUAL do vendedor/gerente ("fila dentro da fila") ──────────────
// Agendamento/retorno/pós-venda vinculado a um responsável entram AQUI quando ele
// está atendendo (não furam a fila principal nem somem). Ao finalizar, o sistema
// sugere iniciar o próximo. FKs soft (como o resto do módulo da fila).
enum PersonalQueueItemType {
  AGENDAMENTO
  RETORNO
  POS_VENDA
  OUTRO
}

enum PersonalQueueItemStatus {
  AGUARDANDO
  CHAMADO
  EM_ATENDIMENTO
  TRANSFERIDO
  CONCLUIDO
  CANCELADO
}

model AgentPersonalQueueItem {
  id                  String                  @id @default(cuid())
  tenantId            String
  unitId              String
  agentUserId         String // responsável (vendedor/gerente) dono do item
  customerId          String?
  dealId              String?
  leadId              String?
  arrivalId           String? // chegada de origem, se veio de "cliente na loja"
  attendanceId        String? // atendimento criado ao iniciar
  itemType            PersonalQueueItemType
  status              PersonalQueueItemStatus @default(AGUARDANDO)
  priority            Int                     @default(0)
  source              String?
  customerName        String?
  customerPhone       String?
  notes               String?
  queuedAt            DateTime                @default(now())
  calledAt            DateTime?
  startedAt           DateTime?
  finishedAt          DateTime?
  transferredToUserId String?
  createdByUserId     String
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([tenantId, unitId, agentUserId, status])
  @@index([tenantId, unitId, status])
  @@index([agentUserId, status])
  @@map("agent_personal_queue_items")
}

// Fila por unidade/dia (agrupador). Uma fila por unidade por dia.
model SellerQueue {
  id        String    @id @default(cuid())
  tenantId  String
  unitId    String
  date      DateTime  @db.Date
  status    String    @default("OPEN") // OPEN | CLOSED
  openedAt  DateTime  @default(now())
  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  entries     SellerQueueEntry[]
  attendances SellerQueueAttendance[]
  arrivals    SellerQueueCustomerArrival[]
  events      SellerQueueEvent[]

  @@unique([tenantId, unitId, date])
  @@index([tenantId])
  @@index([unitId])
  @@index([date])
  @@index([status])
  @@map("seller_queues")
}

// Vendedor presente na fila (posição + status).
model SellerQueueEntry {
  id               String                 @id @default(cuid())
  tenantId         String
  unitId           String
  queueId          String
  sellerId         String
  status           SellerQueueEntryStatus @default(WAITING)
  position         Int                    @default(0)
  joinedAt         DateTime               @default(now())
  lastActiveAt     DateTime?
  pausedAt         DateTime?
  leftAt           DateTime?
  blocked          Boolean                @default(false)
  lastAttendanceAt DateTime?
  attendanceCount  Int                    @default(0)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  queue SellerQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@unique([queueId, sellerId])
  @@index([tenantId])
  @@index([unitId])
  @@index([queueId])
  @@index([sellerId])
  @@index([status])
  @@map("seller_queue_entries")
}

// Cliente que chegou na loja. Qualquer vendedor presente registra; NÃO escolhe quem atende.
model SellerQueueCustomerArrival {
  id                String   @id @default(cuid())
  tenantId          String
  unitId            String
  queueId           String
  registeredById    String // quem clicou "cliente na loja"
  customerName      String?
  customerPhone     String?
  customerEmail     String?
  customerIsWhatsapp Boolean @default(false)
  customerId        String? // Customer vinculado (recorrente)
  leadId            String? // lead aberto (recorrente)
  recurring         Boolean  @default(false)
  suggestedSellerId String? // vendedor responsável (recorrente)
  requestedSellerId String? // cliente pediu pelo nome (exige confirmação/regra)
  status            String   @default("PENDING") // PENDING | CALLING | ASSIGNED | DONE | CANCELED
  notes             String?
  escalationLevel   Int? // índice do nível de escalonamento atual (config)
  escalationAttempt Int? // tentativa dentro do nível atual
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  queue       SellerQueue             @relation(fields: [queueId], references: [id], onDelete: Cascade)
  attendances SellerQueueAttendance[]

  @@index([tenantId])
  @@index([unitId])
  @@index([queueId])
  @@index([status])
  @@index([createdAt])
  @@map("seller_queue_customer_arrivals")
}

// Chamada → aceite → atendimento → resultado.
model SellerQueueAttendance {
  id             String                  @id @default(cuid())
  tenantId       String
  unitId         String
  queueId        String
  sellerId       String
  arrivalId      String?
  status         String                  @default("CALLED") // CALLED | ACCEPTED | IN_ATTENDANCE | FINISHED | REJECTED | EXPIRED
  type           SellerAttendanceType?
  visitType      String? // natureza da visita (config-driven): CLIENTE_PORTA | AGENDAMENTO | RETORNO | POS_VENDA | RETIRADA_CARRO | ENTREGA_VEICULO | DOCUMENTACAO | TEST_DRIVE | AVALIACAO | OUTRO
  result         SellerAttendanceResult?
  calledAt       DateTime                @default(now())
  acceptDeadline DateTime?
  acceptedAt     DateTime?
  rejectedAt     DateTime?
  startedAt      DateTime?
  finishedAt     DateTime?
  rejectReason   String?
  notes          String?
  leadId         String? // lead gerado/vinculado
  dealId         String? // negociação gerada (resultado)
  customerId     String?
  createdById    String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  queue   SellerQueue                 @relation(fields: [queueId], references: [id], onDelete: Cascade)
  arrival SellerQueueCustomerArrival? @relation(fields: [arrivalId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([unitId])
  @@index([queueId])
  @@index([sellerId])
  @@index([status])
  @@index([calledAt])
  @@map("seller_queue_attendances")
}

// Histórico/auditoria de TODOS os eventos da fila.
model SellerQueueEvent {
  id           String               @id @default(cuid())
  tenantId     String
  unitId       String?
  queueId      String?
  type         SellerQueueEventType
  sellerId     String? // sujeito do evento (vendedor)
  actorId      String? // quem executou a ação
  arrivalId    String?
  attendanceId String?
  entryId      String?
  reason       String?
  metadata     Json?
  createdAt    DateTime             @default(now())

  queue SellerQueue? @relation(fields: [queueId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([unitId])
  @@index([queueId])
  @@index([sellerId])
  @@index([type])
  @@index([createdAt])
  @@map("seller_queue_events")
}

// Evento de presença (NÃO contínuo): só em check-in/chamada/aceite/revalidação/check-out/pausa.
model SellerPresenceCheck {
  id             String               @id @default(cuid())
  tenantId       String
  unitId         String
  sellerId       String
  method         SellerPresenceMethod
  context        String               @default("CHECK_IN") // CHECK_IN | CALL | ACCEPT | REVALIDATION | CHECK_OUT | PAUSE | RESUME
  success        Boolean              @default(false)
  latitude       Float?
  longitude      Float?
  accuracyM      Float?
  distanceM      Float? // distância à unidade (geofence)
  deviceId       String?
  overrideById   String? // gerente/líder que liberou manualmente
  overrideReason String?
  createdAt      DateTime             @default(now())

  @@index([tenantId])
  @@index([unitId])
  @@index([sellerId])
  @@index([createdAt])
  @@map("seller_presence_checks")
}

// Configuração da fila por unidade (geofence/QR/timeout/horário/regras). UMA por unidade.
model SellerQueueUnitConfig {
  id                            String   @id @default(cuid())
  tenantId                      String
  unitId                        String
  active                        Boolean  @default(false)
  presenceMethods               String[] // ex.: ["GPS","QR_CODE","DEVICE_CHECK"]
  geofenceLat                   Float?
  geofenceLng                   Float?
  geofenceRadiusM               Int      @default(150)
  qrSecret                      String? // segredo do QR fixo da loja (token rotacionável)
  acceptTimeoutSeconds          Int      @default(60)
  requireRevalidationOnAccept   Boolean  @default(true)
  openTime                      String? // "HH:MM"
  closeTime                     String? // "HH:MM"
  allowedDays                   String[] // ["MON",...]
  recurringCustomerRule         String   @default("RESPONSIBLE") // RESPONSIBLE | QUEUE
  requestByNameRequiresApproval Boolean  @default(true)
  // Avisos/alertas da fila (configuráveis pelo ADM por unidade).
  alertSound                    Boolean  @default(true)  // som em loop na tela do vendedor da vez
  alertSoundType                String   @default("siren") // modelo do som (siren|beep|chime|alarm|bell|soft)
  alertBrowserPush              Boolean  @default(true)  // notificação do navegador (aba minimizada)
  alertWhatsapp                 Boolean  @default(true)  // WhatsApp ao vendedor da vez (best-effort)
  alertWhatsappManagers         Boolean  @default(true)  // WhatsApp à gestão em timeout/sem vendedor
  alertRepeatSeconds            Int      @default(10)    // intervalo do som/alerta repetido até aceitar
  allowChooseSeller             Boolean  @default(true)  // gestão pode escolher o vendedor (auto-organização)
  config                        Json?    // extras por unidade (ex.: estratégia anti-abuso autoBlock)
  updatedById                   String?
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@unique([tenantId, unitId])
  @@index([tenantId])
  @@index([unitId])
  @@map("seller_queue_unit_configs")
}

// Penalidade/bloqueio de vendedor (timeout, no-show, bloqueio manual).
model SellerQueuePenalty {
  id          String    @id @default(cuid())
  tenantId    String
  unitId      String
  sellerId    String
  type        String // TIMEOUT | NO_SHOW | MANUAL_BLOCK | OTHER
  reason      String?
  points      Int       @default(0)
  active      Boolean   @default(true)
  appliedById String?
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([unitId])
  @@index([sellerId])
  @@index([active])
  @@map("seller_queue_penalties")
}

// Sessão de PÓS-VENDAS: o colaborador fica PAUSADO na fila (mantém a posição) e
// só volta com autorização de um superior. status: ACTIVE → RETURN_REQUESTED →
// DONE. Standalone (sem relações) para não tocar tabelas existentes.
model SellerQueuePosVenda {
  id                String    @id @default(cuid())
  tenantId          String
  unitId            String
  queueId           String
  sellerId          String
  attendanceId      String?
  status            String    @default("ACTIVE") // ACTIVE | RETURN_REQUESTED | DONE
  returnRequestedAt DateTime?
  startedById       String?
  authorizedById    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([queueId])
  @@index([sellerId])
  @@index([status])
  @@map("seller_queue_pos_vendas")
}

// Férias/Ausências do colaborador na fila (Fase 2). Standalone (sem relações)
// para não tocar tabelas existentes. Colaborador com ausência ATIVA no período
// não entra na fila (bloqueado no check-in), não vira vendedor da vez e não
// recebe push — logo fica fora do escalonamento. Datas em UTC.
// type: FERIAS|FOLGA|ATESTADO|TREINAMENTO|AUSENCIA|BLOQUEIO_ADM|OUTRO
// status: PROGRAMADO|ATIVO|ENCERRADO|CANCELADO
model SellerVacation {
  id           String   @id @default(cuid())
  tenantId     String
  unitId       String
  sellerId     String
  type         String   @default("FERIAS")
  startAt      DateTime
  endAt        DateTime
  reason       String?
  status       String   @default("PROGRAMADO")
  autoReturn   Boolean  @default(true)
  createdById  String?
  canceledById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([unitId])
  @@index([sellerId])
  @@index([status])
  @@map("seller_vacations")
}

// Suspeita de fraude/manipulação (aparece nos relatórios).
model SellerQueueFraudFlag {
  id           String    @id @default(cuid())
  tenantId     String
  unitId       String?
  sellerId     String?
  actorId      String?
  arrivalId    String?
  attendanceId String?
  kind         String // CHECK_IN_OUTSIDE | FAKE_CUSTOMER | FAVORITISM | IMPROPER_SKIP | DUPLICATE | OFF_SYSTEM | DISPUTE | MANIPULATION | OTHER
  severity     String    @default("LOW") // LOW | MEDIUM | HIGH
  detail       String?
  status       String    @default("OPEN") // OPEN | REVIEWED | DISMISSED | CONFIRMED
  reviewedById String?
  reviewedAt   DateTime?
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
  @@index([unitId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@map("seller_queue_fraud_flags")
}
