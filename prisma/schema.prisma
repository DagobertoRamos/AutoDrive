// ═════════════════════════════════════════════════════════════════════════════
// GOOGLE SHEETS & IMPORTAÇÃO
// ═════════════════════════════════════════════════════════════════════════════

model GoogleSheetConfig {
  id            String    @id @default(cuid())
  tenantId      String?
  unitId        String? // unidade vinculada para importação
  name          String
  spreadsheetId String
  description   String?
  active        Boolean   @default(true)
  columnMapping Json? // mapeamento de colunas (índice → campo)
  dedupeField   String?   @default("negotiation") // campo de deduplicação
  lastSyncAt    DateTime?
  syncStatus    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  tabs            GoogleSheetTab[]
  importJobs      ImportJob[]
  autoSync        GoogleSheetsAutoSyncConfig?
  sheetImportRows SheetImportRow[]

  @@index([tenantId])
  @@map("google_sheet_configs")
}

model GoogleSheetTab {
  id             String       @id @default(cuid())
  configId       String
  internalName   String
  sheetName      String
  gid            String? // Google Sheet numeric tab GID (ex: "1507200471")
  monthReference String? // ex: "Abril", "Maio", "Junho"
  sortOrder      Int?         @default(0)
  description    String?
  tabType        SheetTabType @default(PERSONALIZADO)
  active         Boolean      @default(true)
  headerRow      Int          @default(1)
  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncError  String?
  totalRowsLast  Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  config     GoogleSheetConfig      @relation(fields: [configId], references: [id], onDelete: Cascade)
  columnMaps GoogleSheetColumnMap[]
  importJobs ImportJob[]

  @@index([configId])
  @@map("google_sheet_tabs")
}

model GoogleSheetColumnMap {
  id           String   @id @default(cuid())
  tabId        String
  columnLetter String
  columnHeader String?
  fieldName    String
  fieldLabel   String?
  required     Boolean  @default(false)
  transform    String?
  defaultValue String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  tab GoogleSheetTab @relation(fields: [tabId], references: [id], onDelete: Cascade)

  @@index([tabId])
  @@map("google_sheet_column_maps")
}

model ImportJob {
  id             String          @id @default(cuid())
  configId       String?
  tabId          String?
  triggeredById  String?
  status         ImportJobStatus @default(AGUARDANDO)
  totalRows      Int             @default(0)
  processedRows  Int             @default(0)
  newRecords     Int             @default(0)
  updatedRecords Int             @default(0)
  errorRows      Int             @default(0)
  errors         Json?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime        @default(now())

  // Relations
  config      GoogleSheetConfig? @relation(fields: [configId], references: [id])
  tab         GoogleSheetTab?    @relation(fields: [tabId], references: [id])
  triggeredBy User?              @relation(fields: [triggeredById], references: [id])

  @@index([configId])
  @@index([status])
  @@index([createdAt])
  @@map("import_jobs")
}

// ── Staging de linhas importadas (raw) — base para o processador de negociações ─

model SheetImportRow {
  id             String  @id @default(cuid())
  configId       String
  tabId          String?
  sheetName      String
  rowIndex       Int
  referenceMonth String?

  // Dados brutos mapeados (todos os campos do columnMapping)
  rawData Json

  // Campos-chave denormalizados para query eficiente
  externalId String? // negotiation ID (Negociação Saida ID)
  dedupeKey  String? // configId:sheetName:externalId — para upsert idempotente

  // Campos mapeados mais usados (para listagem sem parsear rawData)
  customerName  String?
  sellerName    String?
  plate         String?
  vehicleModel  String?
  saleDate      String? // string original da planilha
  statusMain    String?
  statusDetail  String?
  saleValue     String?
  docValue      String?
  financedValue String?
  bank          String?
  returnType    String?
  dealType      String?
  timeInStock   String?

  // Estado do processamento
  status         SheetRowStatus @default(PENDENTE)
  dealId         String? // Deal criado/atualizado a partir desta linha
  errorMessage   String?
  warningMessage String?
  processedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  config GoogleSheetConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  deal   Deal?             @relation("DealSheetRows", fields: [dealId], references: [id])

  @@index([configId, status])
  @@index([dedupeKey])
  @@index([dealId])
  @@index([configId, sheetName, externalId])
  @@map("sheet_import_rows")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTO-SYNC — Atualizador automático programável do Google Sheets
// ─────────────────────────────────────────────────────────────────────────────

model GoogleSheetsAutoSyncConfig {
  id                  String         @id @default(cuid())
  importerId          String         @unique
  enabled             Boolean        @default(false)
  mode                AutoSyncMode   @default(SIMULATION)
  frequencyMinutes    Int            @default(30)
  allowedDays         Json           @default("[1,2,3,4,5]") // 0=Dom…6=Sab
  startTime           String         @default("08:00") // HH:mm
  endTime             String         @default("18:00")
  selectedTabs        Json? // null = todas as abas ativas
  actionAfterDownload AutoSyncAction @default(IMPORTAR_PENDENCIAS)
  processDeals        Boolean        @default(false) // processa negociações automaticamente após importação
  notifyOnNewRecords  Boolean        @default(false)
  notifyOnError       Boolean        @default(true)
  errorNotifyTarget   String?
  maxRowsPerRun       Int            @default(500)
  timeoutSeconds      Int            @default(120)
  status              AutoSyncStatus @default(PAUSADO)
  isRunning           Boolean        @default(false)
  lockUntil           DateTime?
  lastRunAt           DateTime?
  nextRunAt           DateTime?
  lastStatus          String?
  lastError           String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // Relations
  importer GoogleSheetConfig         @relation(fields: [importerId], references: [id], onDelete: Cascade)
  jobs     GoogleSheetsAutoSyncJob[]

  @@map("google_sheets_auto_sync_configs")
}

model GoogleSheetsAutoSyncJob {
  id              String              @id @default(cuid())
  importerId      String
  configId        String
  status          AutoSyncJobStatus   @default(RUNNING)
  triggerType     AutoSyncTriggerType @default(AUTO)
  startedAt       DateTime            @default(now())
  finishedAt      DateTime?
  durationMs      Int?
  rowsRead        Int                 @default(0)
  rowsImported    Int                 @default(0)
  rowsUpdated     Int                 @default(0)
  rowsIgnored     Int                 @default(0)
  rowsError       Int                 @default(0)
  sheetsRead      Json?
  sheetsNotFound  Json?
  errors          Json?
  summary         Json?
  createdByUserId String?
  createdAt       DateTime            @default(now())

  // Relations
  config    GoogleSheetsAutoSyncConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  createdBy User?                      @relation("AutoSyncJobCreator", fields: [createdByUserId], references: [id])

  @@index([importerId, createdAt])
  @@index([configId, createdAt])
  @@index([status])
  @@map("google_sheets_auto_sync_jobs")
}

// ═════════════════════════════════════════════════════════════════════════════
// E-MAIL
// ═════════════════════════════════════════════════════════════════════════════

enum EmailPurpose {
  SYSTEM // comunicação geral do sistema (notificações internas, alertas)
  NOTICES // sistema de avisos / notícias enviadas a usuários
  PASSWORD_RESET // recuperação de senha / esqueci minha senha
  TRANSACTIONAL // confirmações, recibos, alterações de cadastro
}

model EmailConfig {
  id           String       @id @default(cuid())
  tenantId     String?
  name         String       @default("Principal")
  purpose      EmailPurpose @default(SYSTEM)
  isDefault    Boolean      @default(false)
  provider     String       @default("smtp") // smtp | sendgrid | resend | mailgun | ses
  smtpHost     String?
  smtpPort     Int          @default(587)
  smtpSecure   Boolean      @default(false)
  smtpUser     String?
  smtpPass     String?
  apiKey       String? // sendgrid / resend / mailgun
  domain       String? // mailgun sending domain
  region       String? // ses region (ex: us-east-1)
  fromName     String
  fromEmail    String
  replyTo      String?
  active       Boolean      @default(true)
  lastTestedAt DateTime?
  lastTestOk   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([tenantId])
  @@index([purpose])
  @@index([provider])
  @@map("email_configs")
}

model EmailTemplate {
  id          String       @id @default(cuid())
  tenantId    String?
  purpose     EmailPurpose
  key         String // identifier for the template (e.g. "password_reset", "welcome")
  name        String // display name
  description String?
  subject     String
  bodyHtml    String       @db.Text
  bodyText    String?      @db.Text
  variables   String[] // list of {{vars}} the template accepts
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([tenantId, purpose, key])
  @@index([tenantId])
  @@index([purpose])
  @@map("email_templates")
}

