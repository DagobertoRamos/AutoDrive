// =============================================================================
// AutoDrive — Sua loja no piloto automático
// Schema Prisma — PostgreSQL — Multi-tenant SaaS Enterprise
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═════════════════════════════════════════════════════════════════════════════
// ENUMS
// ═════════════════════════════════════════════════════════════════════════════

/// Hierarquia de perfis do sistema (pirâmide de acesso)
enum UserRole {
  MASTER // Acesso total — controle da plataforma SaaS
  ADM // Administrador do tenant — quase total
  GERENTE_GERAL // Gerencia unidades, gerentes, relatórios
  GERENTE_ADMINISTRATIVO // Gerente administrativo/financeiro do tenant (ILA/IOF, garantias)
  GERENTE // Gerencia equipe e pendências da unidade
  VENDEDOR_LIDER // Líder de equipe com permissões ampliadas
  VENDEDOR // Vê suas próprias pendências e comissões
  FINANCEIRO // Setor financeiro — ILA/IOF, conferência, garantias
  USUARIO_LIDER // Módulos específicos com permissão ampliada
  USUARIO // Acesso básico conforme permissões
}

enum UserStatus {
  ATIVO
  INATIVO
  PENDENTE
  BLOQUEADO
  SUSPENSO // suspensão temporária (ex.: férias, investigação) — diferente de BLOQUEADO (segurança) e INATIVO (encerrado)
}

enum TenantPlan {
  BASICO
  PRO
  VIP
  CUSTOM
}

enum TenantStatus {
  ATIVO
  SUSPENSO
  BLOQUEADO
  BANIDO
  CANCELADO
  TESTE
  INADIMPLENTE
  PAUSADO
}

enum PartnerRole {
  SOCIO_ADMINISTRADOR
  SOCIO
  REPRESENTANTE_LEGAL
  PROCURADOR
}

enum PendencyPriority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum PendencyStatus {
  ABERTA
  EM_ANDAMENTO
  AGUARDANDO_RESPOSTA
  PAUSADA
  FINALIZADA
  REATIVADA
  CANCELADA
  VENCIDA
}

enum DealType {
  VENDA
  COMPRA
  TROCA
  CONSIGNACAO
}

enum DealStatus {
  // ── Status base (legado — mantidos para compatibilidade) ──────────────────
  RASCUNHO
  AGUARDANDO_LIBERACAO // legado → equivale a AGUARDANDO_APROVACAO
  LIBERADA // legado → equivale a APROVADA
  RECUSADA // legado → equivale a DESAPROVADA
  EM_ANDAMENTO
  FINALIZADA
  CANCELADA
  REABERTA

  // ── Status expandidos (motor completo) ───────────────────────────────────
  EM_PREENCHIMENTO
  AGUARDANDO_APROVACAO
  APROVADA
  DESAPROVADA
  DEVOLVIDA_PARA_CORRECAO
  AGUARDANDO_SINAL
  SINAL_RECEBIDO
  RESERVADA
  AGUARDANDO_FINANCEIRO
  FINANCEIRO_APROVADO
  FINANCEIRO_REPROVADO
  AGUARDANDO_DOCUMENTACAO
  DOCUMENTACAO_CONCLUIDA
  AGUARDANDO_CONTRATO
  CONTRATO_GERADO
  AGUARDANDO_ASSINATURA
  ASSINADA
  AGUARDANDO_ENTREGA
  ENTREGUE
  BLOQUEADA
