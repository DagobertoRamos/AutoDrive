# =============================================================================
# AutoDrive — Sheets Service — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o .env com credenciais reais.

# -----------------------------------------------------------------------------
# CREDENCIAIS GOOGLE (Service Account)
# -----------------------------------------------------------------------------
# Cole aqui o JSON completo da Service Account em UMA ÚNICA LINHA.
# Substitua cada quebra de linha real dentro de private_key por \n literal.
#
# Exemplo (tudo em uma linha, sem quebras externas):
# GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"newagent-irof","private_key_id":"abc123","private_key":"-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n","client_email":"easycar@newagent-irof.iam.gserviceaccount.com","client_id":"101228797611614544104","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/easycar%40newagent-irof.iam.gserviceaccount.com","universe_domain":"googleapis.com"}
#
# Alternativa: encode em Base64 e prefixe com base64:
# GOOGLE_SHEETS_CREDENTIALS=base64:eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii4uLn0=
GOOGLE_SHEETS_CREDENTIALS=

# -----------------------------------------------------------------------------
# PAINEL MASTER — Google Sheets
# -----------------------------------------------------------------------------
# ID da planilha (parte da URL após /d/ e antes de /edit)
# Ex: https://docs.google.com/spreadsheets/d/SEU_ID_AQUI/edit
MASTER_SHEET_ID=

# GID padrão da aba (número após ?gid= na URL). 0 = primeira aba.
MASTER_SHEET_GID=0

# Nome da aba padrão (alternativa ao GID; GID tem prioridade se ambos fornecidos)
MASTER_SHEET_TAB=Abril

# -----------------------------------------------------------------------------
# BANCO DE DADOS (opcional — para persistência dos dados importados)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://usuario:senha@localhost:5432/autodrive

# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=false

# -----------------------------------------------------------------------------
# SINCRONIZAÇÃO AUTOMÁTICA
# -----------------------------------------------------------------------------
# Intervalo em minutos entre cada sincronização automática
SYNC_INTERVAL_MINUTES=5

# Habilitar/desabilitar o scheduler automático (true/false)
SYNC_ENABLED=true
