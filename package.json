{
  "name": "autodrive",
  "version": "1.0.0",
  "description": "AutoDrive - Plataforma SaaS multi-tenant de gestão comercial para lojas de veículos",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && node --max-old-space-size=6144 ./node_modules/next/dist/bin/next build --turbopack",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" prisma/seed.ts",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "danger:delete-negotiations-commissions": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/danger-delete-negotiations-and-commissions.ts"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@hookform/resolvers": "^3.3.4",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@tanstack/react-query": "^5.24.1",
    "@types/nodemailer": "^8.0.0",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "bufferutil": "^4.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "googleapis": "^172.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.344.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.7",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.0",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "tailwind-merge": "^2.2.1",
    "utf-8-validate": "^6.0.6",
    "web-push": "^3.6.7",
    "ws": "^8.21.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.25",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "postcss": "^8.4.35",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  }
}
