{
  "manifest_version": 3,
  "name": "AutoConf → AutoDrive (importador de negociações)",
  "version": "0.1.0",
  "description": "Lê as negociações do AutoConf (sessão logada) e prepara a importação no AutoDrive para gerar comissão.",
  "permissions": ["storage", "activeTab", "downloads"],
  "host_permissions": ["https://app.autoconf.com.br/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoConf → AutoDrive"
  },
  "content_scripts": [
    {
      "matches": ["https://app.autoconf.com.br/*"],
      "js": ["scanner.js"],
      "run_at": "document_idle"
    }
  ]
}
