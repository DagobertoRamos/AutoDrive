{
  "manifest_version": 3,
  "name": "AutoConf → AutoDrive (importador de negociações)",
  "version": "0.2.0",
  "description": "Lê as negociações do AutoConf (sessão logada) e importa no AutoDrive para gerar comissão.",
  "permissions": ["storage", "activeTab", "downloads"],
  "host_permissions": ["https://app.autoconf.com.br/*", "https://auto-drive-mocha.vercel.app/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoConf → AutoDrive"
  },
  "content_scripts": [
    {
      "matches": ["https://app.autoconf.com.br/*"],
      "js": ["scanner.js"],
      "run_at": "document_idle"
    }
  ]
}
